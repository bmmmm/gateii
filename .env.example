# ─── Proxy mode ───────────────────────────────────────────────────────────────
#
#   passthrough  Client's own API credential (e.g. Claude Max OAuth, personal
#                sk-ant-..., or OR sk-or-v1-...) is forwarded as-is. No server
#                key, no user management, no keys.json. Simplest single-user
#                setup.
#
#   apikey       Clients authenticate with sk-proxy-... keys. Each entry in
#                data/keys.json binds one proxy key to {user, provider,
#                upstream_key} — so different users can go to different
#                upstreams (Anthropic, OpenRouter, ...) through the same proxy.
#                Issue keys via: scripts/admin.sh add <user> --provider <p>
#                --upstream-key <k>.
#
PROXY_MODE=passthrough

# Passthrough only — display name in Grafana. Ignored in apikey mode (user
# names come from keys.json). Leave empty to derive from the client key suffix.
PASSTHROUGH_USER=

# ─── Upstream credentials (apikey mode) ───────────────────────────────────────
# Recommended: do NOT set these globally — instead pass per user via
#   admin.sh add <user> --provider <p> --upstream-key <k>
# which stores the credential in keys.json under that user only.
#
# These env vars act as a FALLBACK for users whose keys.json entry has an
# empty upstream_key. Useful for a solo setup where all OR traffic shares
# one key.
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...

# ─── Admin API auth ───────────────────────────────────────────────────────────
# Required for apikey mode (admin.sh, console, bootstrap handshake all use it).
# In passthrough mode it's optional — without a token, /console is still
# reachable on the Docker network but cannot mutate state.
# Generate:  openssl rand -hex 32
ADMIN_TOKEN=

# Grafana admin password — required when deploying with a strict-env compose
# (e.g. a hardened production variant). The local dev compose has anonymous
# access enabled by default and ignores this.
# GRAFANA_ADMIN_PASSWORD=

# ─── Routing / ports ──────────────────────────────────────────────────────────
# PROXY_HOST=localhost
# PROXY_PORT=8888
# GRAFANA_PORT=3001

# Interface to bind the proxy port to. Default: 127.0.0.1 (loopback only).
# Set to 0.0.0.0 if other LAN devices should reach this instance — only do
# that if you have ADMIN_TOKEN set AND either PROXY_MODE=apikey with real
# keys in data/keys.json, or you explicitly want a LAN-open passthrough.
# PROXY_BIND=0.0.0.0
#
# Same for Grafana (:3001) and Prometheus (:9090). Both default to 127.0.0.1;
# set to 0.0.0.0 only if you need remote dashboard access, ideally behind a
# reverse proxy with auth.
# GRAFANA_BIND=0.0.0.0
# PROMETHEUS_BIND=0.0.0.0

# Optional: URL of a remote gateii instance you run elsewhere.
# Used by `scripts/admin.sh switch remote` to flip Claude Code's base URL
# over to that remote proxy. Leave unset if you only run gateii locally.
# REMOTE_URL=http://your-remote-host:8888
#
# Optional display label for the remote (default: "remote"). Shown in the
# "Switched to X proxy" confirmation and health-check output.
# REMOTE_NAME=prod

# ─── Rate limit window ────────────────────────────────────────────────────────
# Duration of the Anthropic token rate limit window in seconds.
# Default (empty): read from providers.json (default 18000 = 5h).
# RATE_LIMIT_5H_WINDOW_SECONDS=18000

# ─── History retention ────────────────────────────────────────────────────────
# Prometheus retention. Default (empty or 0) = unlimited.
# Options: 30d, 90d, 180d, 365d
# HISTORY_RETENTION=

# ─── Circuit breaker ──────────────────────────────────────────────────────────
# Per-provider breaker: open on N consecutive 5xx/timeouts, cool down for S
# seconds before trying a probe. Leave unset to use Lua defaults (5 / 30s).
# CB_FAILURE_THRESHOLD=5
# CB_COOLDOWN_SECONDS=30

# ─── Bootstrap handshake TTLs ─────────────────────────────────────────────────
# Timings for the one-time-code bootstrap flow (seconds). Defaults in Lua:
#   CONFIRM_TTL=300   — how long a confirm window is valid after generation
#   PENDING_TTL=600   — default lifetime of a bootstrap code
#   PENDING_MAX=3600  — hard cap on PENDING_TTL (per-request override ceiling)
#   NONCE_TTL=60      — replay-window for nonces inside a pending code
# BOOTSTRAP_CONFIRM_TTL=300
# BOOTSTRAP_PENDING_TTL=600
# BOOTSTRAP_PENDING_MAX=3600
# BOOTSTRAP_NONCE_TTL=60

# ─── Auth cache ───────────────────────────────────────────────────────────────
# Worker-local in-memory auth cache for API-key lookups. Short TTLs keep
# revoked keys from lingering; long TTLs reduce keys.json re-reads.
# AUTH_CACHE_NEG_TTL=60    # seconds to cache "invalid key" verdicts
# AUTH_CACHE_POS_TTL=300   # seconds to cache "valid key" entries

# ─── Rate limiter ─────────────────────────────────────────────────────────────
# Per-client rate limit (requests/sec avg + burst). Default: 1 rps, burst 10
# (= 60/min with short spikes).
# RATE_LIMIT_RPS=1
# RATE_LIMIT_BURST=10

# ─── Admin console URL ────────────────────────────────────────────────────────
# URL surfaced in 429 error bodies so clients know where to manage their key.
# Default fits the local dev setup.
# CONSOLE_URL=http://localhost:8888/console

# ─── Counter retention ────────────────────────────────────────────────────────
# How long per-user/provider/model token counters persist in shared dict.
# Default: 60 days.
# COUNTER_RETENTION_DAYS=60

# ─── Health-check timeouts (ms) ───────────────────────────────────────────────
# Used by GET /internal/admin/health when probing upstream providers.
# Bump these when hitting providers that commonly respond > 3s.
# HEALTH_CHECK_CONNECT_MS=1500
# HEALTH_CHECK_SEND_MS=1500
# HEALTH_CHECK_READ_MS=3000

# ─── Plugins ──────────────────────────────────────────────────────────────────
# Manage via: scripts/admin.sh plugin <list|enable|disable|status> <name>
#
# console — admin web console at /console (key management, limits, live stats)
# CONSOLE_ENABLED=0
#
# git-tracking — track git activity (commits, lines changed) alongside tokens
# GIT_TRACKING_ENABLED=0
# GIT_AUTHOR=
# GIT_TRACKING_INTERVAL=300
