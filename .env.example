# --- Proxy mode ---
#
#   passthrough  Your own Anthropic key is forwarded transparently.
#                Works with Claude Max plan (OAuth) and regular API keys.
#                No key stored on the server.
#
#   apikey       gateii uses a shared server-side ANTHROPIC_API_KEY.
#                Clients get proxy keys via scripts/admin.sh.
#                Keys stored in data/keys.json (auto-created, gitignored).
#
PROXY_MODE=passthrough

# Display name in Grafana and admin stats (passthrough mode only).
# If omitted, a stable ID is derived from the last 8 chars of the client key.
PASSTHROUGH_USER=

# Server-side Anthropic key — only needed when PROXY_MODE=apikey
# ANTHROPIC_API_KEY=sk-ant-...

# --- Admin API auth ---
# Optional shared secret for /internal/admin/* endpoints.
# When set, scripts/admin.sh and the /console UI must send X-Admin-Token: <value>.
# Recommended: openssl rand -hex 32
# Without it, the admin API is protected only by the Docker-network IP allow-list
# — any compromised sidecar on the gateii network could script admin actions.
# ADMIN_TOKEN=

# --- Ports ---
# PROXY_HOST=localhost
# PROXY_PORT=8888
# GRAFANA_PORT=3001

# --- Rate limit window ---
# Duration of the Anthropic token rate limit window in seconds.
# Default (empty): read from providers.json (window_seconds field, default 18000 = 5h).
# Override to match your actual plan if Anthropic changes the window length.
# Used by the auto-reset timer to restore ratelimit_remaining between sessions.
# RATE_LIMIT_5H_WINDOW_SECONDS=18000

# --- History retention ---
# How long Prometheus keeps metrics. Default (empty or 0) = unlimited.
# Options: 30d (1 month), 90d (3 months), 180d (6 months), 365d (1 year)
# HISTORY_RETENTION=

# --- Plugins ---
# Manage via: ./scripts/admin.sh plugin <list|enable|disable|status> <name>
#
# console — admin web console at /console (key management, limits, live stats)
# CONSOLE_ENABLED=0
#
# git-tracking — track git activity (commits, lines changed) alongside token usage
# GIT_TRACKING_ENABLED=0          # set to 1 by admin.sh plugin enable git-tracking
# GIT_AUTHOR=                     # filter by author (empty = all commits)
# GIT_TRACKING_INTERVAL=300       # refresh interval in seconds (default: 5m)
