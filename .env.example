# --- Proxy mode ---
#
#   passthrough  Your own Anthropic key is forwarded transparently.
#                Works with Claude Max plan (OAuth) and regular API keys.
#                No key stored on the server. No Redis auth.
#
#   apikey       gateii uses a shared server-side ANTHROPIC_API_KEY.
#                Clients get proxy keys via scripts/admin.sh.
#
PROXY_MODE=passthrough

# Display name in Grafana and admin stats (passthrough mode only).
# If omitted, a stable ID is derived from the last 8 chars of the client key.
PASSTHROUGH_USER=

# Server-side Anthropic key — only needed when PROXY_MODE=apikey
# ANTHROPIC_API_KEY=sk-ant-...

# Response cache TTL in seconds (default 1 hour).
# Non-streaming requests with identical content are served from cache.
CACHE_TTL=3600
