        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "100 * gateii_openrouter_free_requests{window=\"day\"} / clamp_min(gateii_openrouter_free_requests{window=\"day\"} + gateii_openrouter_free_requests_remaining{window=\"day\"}, 1)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
