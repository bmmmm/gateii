{
  "id": null,
  "uid": "gateii-ops",
  "title": "gateii \u2014 Operations",
  "tags": [
    "gateii",
    "ops"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "description": "Live operations view \u2014 last hour of traffic, errors, and security events. Rate-limit window state lives on the Efficiency & Health dashboard.",
  "links": [
    {
      "title": "Cost & Usage",
      "type": "link",
      "url": "/d/gateii-cost",
      "icon": "dollar",
      "targetBlank": false
    },
    {
      "title": "Efficiency & Health",
      "type": "link",
      "url": "/d/gateii-eff",
      "icon": "cloud",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "query": "label_values(gateii_requests_total, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 300,
      "type": "row",
      "title": "Status",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "title": "Circuit Breaker State (now)",
      "description": "Auto-protects upstream APIs from repeated failures. CLOSED = normal, requests pass through. OPEN = 5 consecutive 5xx/timeouts tripped the breaker; new requests fail fast (503) instead of hammering a broken upstream. HALF_OPEN = cooldown elapsed, one probe request is sent to test recovery \u2014 success reverts to CLOSED, failure reopens.",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 3
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "gateii_circuit_state",
          "legendFormat": "{{provider}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CLOSED",
                  "color": "green"
                },
                "1": {
                  "text": "HALF_OPEN",
                  "color": "yellow"
                },
                "2": {
                  "text": "OPEN",
                  "color": "red"
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "value_and_name"
      }
    },
