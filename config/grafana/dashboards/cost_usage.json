{
  "id": null,
  "uid": "gateii-cost",
  "title": "gateii — Cost & Usage",
  "tags": ["gateii", "cost"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {"from": "now-31d", "to": "now"},
  "description": "Aggregation window controlled by the Window dropdown. For exact billing-cycle dates (14th → 13th), set the time picker manually; the window dropdown still drives the per-panel aggregation interval.",
  "links": [
    {"title": "Operations", "type": "link", "url": "/d/gateii-ops", "icon": "dashboard", "targetBlank": false},
    {"title": "Efficiency & Health", "type": "link", "url": "/d/gateii-eff", "icon": "cloud", "targetBlank": false}
  ],
  "templating": {
    "list": [
      {
        "name": "window",
        "label": "Window",
        "type": "custom",
        "query": "24h,7d,30d,60d,90d",
        "current": {"selected": true, "text": "30d", "value": "30d"},
        "options": [
          {"selected": false, "text": "24h", "value": "24h"},
          {"selected": false, "text": "7d", "value": "7d"},
          {"selected": true,  "text": "30d", "value": "30d"},
          {"selected": false, "text": "60d", "value": "60d"},
          {"selected": false, "text": "90d", "value": "90d"}
        ],
        "includeAll": false,
        "multi": false
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {"type": "prometheus"},
        "query": "label_values(gateii_requests_total, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 200,
      "type": "row",
      "title": "Claude Code — Totals",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 1,
      "title": "Cost (24h)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 1, "w": 5, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total{model=~\"$model\"}[24h]))", "legendFormat": "24h", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 2,
      "title": "Cost ($window)",
      "type": "stat",
      "gridPos": {"x": 5, "y": 1, "w": 5, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total{model=~\"$model\"}[$window]))", "legendFormat": "window", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 5,
      "title": "Tokens ($window)",
      "type": "stat",
      "gridPos": {"x": 10, "y": 1, "w": 5, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=~\"input|output\",model=~\"$model\"}[$window]))", "legendFormat": "window", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "#B877D9"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 6,
      "title": "Requests ($window)",
      "type": "stat",
      "gridPos": {"x": 15, "y": 1, "w": 5, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_requests_total{model=~\"$model\"}[$window]))", "legendFormat": "Requests", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "#5794F2"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 11,
      "title": "Monthly Forecast",
      "description": "Last 7 days cost rate × 30 days. Linear extrapolation of the current pace.",
      "type": "stat",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(rate(gateii_cost_dollars_total{model=~\"$model\"}[7d])) * 86400 * 30", "legendFormat": "Forecast", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 1000}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 201,
      "type": "row",
      "title": "Claude Code — Cost Breakdown",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 7,
      "title": "Cost by Model ($window)",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 6, "w": 8, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_cost_dollars_total{model=~\"$model\"}[$window]))", "legendFormat": "{{model}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/qwen/i"},    "properties": [{"id": "color", "value": {"fixedColor": "#FF7F00", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/gemma/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#00D4FF", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/llama/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#FFD700", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/phi/i"},     "properties": [{"id": "color", "value": {"fixedColor": "#FF4081", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/mistral/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#F97316", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/deepseek/i"},"properties": [{"id": "color", "value": {"fixedColor": "#A3E635", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},    "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 8,
      "title": "Daily Cost Trend (last 31d)",
      "description": "Per-day cost stacked by model. Fixed 31-day window so the chart always has data regardless of the Window dropdown.",
      "type": "barchart",
      "gridPos": {"x": 8, "y": 6, "w": 16, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_cost_dollars_total{model=~\"$model\"}[1d]))", "legendFormat": "{{model}}", "refId": "A", "interval": "1d"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "custom": {"lineWidth": 1, "fillOpacity": 80, "stacking": {"mode": "normal"}, "axisLabel": ""}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/qwen/i"},    "properties": [{"id": "color", "value": {"fixedColor": "#FF7F00", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/gemma/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#00D4FF", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/llama/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#FFD700", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/phi/i"},     "properties": [{"id": "color", "value": {"fixedColor": "#FF4081", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/mistral/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#F97316", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/deepseek/i"},"properties": [{"id": "color", "value": {"fixedColor": "#A3E635", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},    "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}, "orientation": "auto", "stacking": "normal", "showValue": "auto", "xTickLabelRotation": -45}
    },
    {
      "id": 12,
      "title": "Cost by User ($window)",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 14, "w": 8, "h": 6},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "topk(10, sum by (user) (increase(gateii_cost_dollars_total{model=~\"$model\"}[$window])))", "legendFormat": "{{user}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 10,
      "title": "Tokens by Effort ($window)",
      "description": "Output-token sum per Opus reasoning effort level — proxy for cost since output dominates spend. 'none' = requests without output_config.effort set.",
      "type": "bargauge",
      "gridPos": {"x": 8, "y": 14, "w": 16, "h": 6},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (effort) (increase(gateii_tokens_by_effort_total{type=\"output\",model=~\"$model\"}[$window]))", "legendFormat": "{{effort}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 203,
      "type": "row",
      "title": "Pricing & Subscription",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 14,
      "title": "Cost vs Subscription Break-Even ($window)",
      "description": "Cumulative spend in the selected window vs. typical Anthropic subscription tiers ($20/$100/$200).",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 21, "w": 16, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total{model=~\"$model\"}[$window]))", "legendFormat": "window spend", "refId": "A"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(20)", "legendFormat": "Pro $20", "refId": "B"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(100)", "legendFormat": "Max 5× $100", "refId": "C"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(200)", "legendFormat": "Max 20× $200", "refId": "D"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "window spend"}, "properties": [{"id": "color", "value": {"fixedColor": "#E02F44", "mode": "fixed"}}, {"id": "custom.fillOpacity", "value": 25}]},
          {"matcher": {"id": "byName", "options": "Pro $20"},   "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}, {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}]},
          {"matcher": {"id": "byName", "options": "Max 5× $100"}, "properties": [{"id": "color", "value": {"fixedColor": "#FF9830", "mode": "fixed"}}, {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}]},
          {"matcher": {"id": "byName", "options": "Max 20× $200"}, "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}, {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 20,
      "title": "Active Pricing per 1M Tokens",
      "description": "Current pricing loaded from providers.json, per model + type (input/output/cache_write/cache_read).",
      "type": "table",
      "gridPos": {"x": 16, "y": 21, "w": 8, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "gateii_model_pricing_per_mtok", "format": "table", "instant": true, "refId": "A"}],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true}, "renameByName": {"Value": "USD / 1M tok"}}},
        {"id": "sortBy", "options": {"fields": {}, "sort": [{"field": "model"}, {"field": "type"}]}}
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2},
        "overrides": [
          {"matcher": {"id": "byName", "options": "USD / 1M tok"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-text"}}, {"id": "color", "value": {"mode": "continuous-GrYlRd"}}]}
        ]
      },
      "options": {"showHeader": true, "cellHeight": "sm"}
    },
    {
      "id": 204,
      "type": "row",
      "title": "oMLX — Local Agent Usage",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 29, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 60,
      "title": "oMLX Agent Tasks ($window)",
      "description": "Requests handled by local oMLX models. These have $0 API cost — each task saved is a Haiku call avoided.",
      "type": "stat",
      "gridPos": {"x": 0, "y": 30, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_requests_total{model=~\"(?i)(qwen|gemma|llama|phi|mistral|deepseek).*\"}[$window]))", "legendFormat": "tasks", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "#FF7F00"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 61,
      "title": "oMLX Tokens ($window)",
      "description": "Tokens processed locally. Input tokens saved from Anthropic API.",
      "type": "stat",
      "gridPos": {"x": 6, "y": 30, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=~\"input|output\",model=~\"(?i)(qwen|gemma|llama|phi|mistral|deepseek).*\"}[$window]))", "legendFormat": "tokens", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "#00D4FF"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 62,
      "title": "Est. Savings vs Haiku ($window)",
      "description": "Estimated cost that would have been billed if the same tokens went through Haiku ($0.80/MTok input + $4/MTok output). Actual savings = this value since oMLX costs $0.",
      "type": "stat",
      "gridPos": {"x": 12, "y": 30, "w": 12, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=\"input\",model=~\"(?i)(qwen|gemma|llama|phi|mistral|deepseek).*\"}[$window])) * 0.8 / 1e6 + sum(increase(gateii_tokens_total{type=\"output\",model=~\"(?i)(qwen|gemma|llama|phi|mistral|deepseek).*\"}[$window])) * 4 / 1e6", "legendFormat": "saved", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 3, "color": {"mode": "fixed", "fixedColor": "#56A64B"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 63,
      "title": "oMLX Tasks by Model ($window)",
      "description": "Request volume breakdown per local model.",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 34, "w": 24, "h": 6},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_requests_total{model=~\"(?i)(qwen|gemma|llama|phi|mistral|deepseek).*\"}[$window]))", "legendFormat": "{{model}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/qwen/i"},    "properties": [{"id": "color", "value": {"fixedColor": "#FF7F00", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/gemma/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#00D4FF", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/llama/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#FFD700", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/phi/i"},     "properties": [{"id": "color", "value": {"fixedColor": "#FF4081", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/mistral/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#F97316", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/deepseek/i"},"properties": [{"id": "color", "value": {"fixedColor": "#A3E635", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    }
  ]
}
