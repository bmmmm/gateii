{
  "id": null,
  "uid": "gateii-cost",
  "title": "gateii — Cost & Usage",
  "tags": ["gateii", "cost"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {"from": "now/M+13d", "to": "now"},
  "description": "Billing cycle starts on the 14th of each month. Default time range = current cycle. For previous cycle, set range to `now/M+13d-1M` → `now/M+13d`.",
  "links": [
    {"title": "Operations", "type": "link", "url": "/d/gateii-ops", "icon": "dashboard", "targetBlank": false},
    {"title": "Efficiency & Health", "type": "link", "url": "/d/gateii-eff", "icon": "cloud", "targetBlank": false}
  ],
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {"type": "prometheus"},
        "query": "label_values(gateii_requests_total, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 200,
      "type": "row",
      "title": "Totals",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 1,
      "title": "Cost (24h)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total{model=~\"$model\"}[24h]))", "legendFormat": "24h", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 2,
      "title": "Cost (this cycle)",
      "type": "stat",
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total{model=~\"$model\"}[$__range]))", "legendFormat": "cycle", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 3,
      "title": "Cost (365d)",
      "type": "stat",
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total{model=~\"$model\"}[365d]))", "legendFormat": "365d", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 4,
      "title": "Tokens (24h)",
      "type": "stat",
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=~\"input|output\",model=~\"$model\"}[24h]))", "legendFormat": "24h", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "#B877D9"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 5,
      "title": "Tokens (this cycle)",
      "type": "stat",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=~\"input|output\",model=~\"$model\"}[$__range]))", "legendFormat": "cycle", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "#B877D9"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 6,
      "title": "Requests (this cycle)",
      "type": "stat",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_requests_total{model=~\"$model\"}[$__range]))", "legendFormat": "Requests", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "#5794F2"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 201,
      "type": "row",
      "title": "Breakdown",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 7,
      "title": "Cost by Model (this cycle)",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_cost_dollars_total{model=~\"$model\"}[$__range]))", "legendFormat": "{{model}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 8,
      "title": "Daily Cost Trend (this cycle)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_cost_dollars_total{model=~\"$model\"}[1d]))", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "custom": {"lineWidth": 2, "fillOpacity": 20, "stacking": {"mode": "normal"}}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 9,
      "title": "Requests by Effort (this cycle)",
      "description": "Opus reasoning effort dimension. 'none' = requests without output_config.effort set.",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (effort) (increase(gateii_requests_by_effort_total{model=~\"$model\"}[$__range]))", "legendFormat": "{{effort}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 10,
      "title": "Tokens by Effort (this cycle)",
      "description": "Output-token sum per effort level — proxy for cost, since output dominates cost.",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (effort) (increase(gateii_tokens_by_effort_total{type=\"output\",model=~\"$model\"}[$__range]))", "legendFormat": "{{effort}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 202,
      "type": "row",
      "title": "Top Users",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 12,
      "title": "Top Users by Cost (this cycle)",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 23, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "topk(10, sum by (user) (increase(gateii_cost_dollars_total{model=~\"$model\"}[$__range])))", "legendFormat": "{{user}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 13,
      "title": "Top Users by Requests (this cycle)",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 23, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "topk(10, sum by (user) (increase(gateii_requests_total{model=~\"$model\"}[$__range])))", "legendFormat": "{{user}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 203,
      "type": "row",
      "title": "Forecast & Pricing",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 31, "w": 24, "h": 1},
      "panels": []
    },
    {
      "id": 11,
      "title": "Monthly Forecast (linear)",
      "description": "Last 7 days cost rate extrapolated over 30 days. Simple linear projection — current pace × month.",
      "type": "stat",
      "gridPos": {"x": 0, "y": 32, "w": 8, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(rate(gateii_cost_dollars_total{model=~\"$model\"}[7d])) * 86400 * 30", "legendFormat": "Forecast", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 1000}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 20,
      "title": "Active Pricing per 1M Tokens",
      "description": "Current pricing loaded from providers.json, per model + type (input/output/cache_write/cache_read).",
      "type": "table",
      "gridPos": {"x": 8, "y": 32, "w": 16, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "gateii_model_pricing_per_mtok", "format": "table", "instant": true, "refId": "A"}],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true}, "renameByName": {"Value": "USD / 1M tok"}}},
        {"id": "sortBy", "options": {"fields": {}, "sort": [{"field": "model"}, {"field": "type"}]}}
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2},
        "overrides": [
          {"matcher": {"id": "byName", "options": "USD / 1M tok"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-text"}}, {"id": "color", "value": {"mode": "continuous-GrYlRd"}}]}
        ]
      },
      "options": {"showHeader": true, "cellHeight": "sm"}
    },
    {
      "id": 14,
      "title": "Cost vs Subscription Break-Even (this cycle)",
      "description": "Cumulative billing-cycle spend vs. typical Anthropic subscription tiers ($20/$100/$200).",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 40, "w": 24, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total{model=~\"$model\"}[$__range]))", "legendFormat": "cycle spend", "refId": "A"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(20)", "legendFormat": "Pro $20", "refId": "B"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(100)", "legendFormat": "Max 5× $100", "refId": "C"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(200)", "legendFormat": "Max 20× $200", "refId": "D"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "cycle spend"}, "properties": [{"id": "color", "value": {"fixedColor": "#E02F44", "mode": "fixed"}}, {"id": "custom.fillOpacity", "value": 25}]},
          {"matcher": {"id": "byName", "options": "Pro $20"},   "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}, {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}]},
          {"matcher": {"id": "byName", "options": "Max 5× $100"}, "properties": [{"id": "color", "value": {"fixedColor": "#FF9830", "mode": "fixed"}}, {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}]},
          {"matcher": {"id": "byName", "options": "Max 20× $200"}, "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}, {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    }
  ]
}
