#!/bin/bash
# scripts/agent — local omlx-backed task runner
#
# Routes simple tasks (commit messages, summaries, classification, etc.) to a
# local Qwen3.5-9B model via gateii → omlx, instead of burning Claude API
# tokens on them. Parent Claude Code calls this via Bash() when CLAUDE.md
# routing rules match.
#
# Usage:
#   echo "<input>" | scripts/agent run <task>
#   scripts/agent tasks                    # list available tasks
#   scripts/agent list                     # show running + recent (Stage 2)
#
# All tasks share these defaults:
#   - model: Qwen3.5-9B-MLX-4bit
#   - chat_template_kwargs: enable_thinking=false
#   - temperature: 0.2 (deterministic)
#   - timeout: 60s
#
# Routing path:
#   scripts/agent → gateii :8888 (x-provider:omlx) → omlx :8000 → Qwen3.5-9B
#
# State (Stage 2+):
#   data/agents/active.json   currently-running agents
#   data/agents/log.jsonl     append-only history
#   data/agents/lock          flock for concurrency=1

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$PROJECT_DIR/data/agents"
TASKS_JSON="$PROJECT_DIR/config/agents/tasks.json"

GATEII_URL="${GATEII_URL:-http://localhost:8888}"
TIMEOUT="${OMLX_AGENT_TIMEOUT:-60}"
MODEL="${OMLX_AGENT_MODEL:-Qwen3.5-9B-MLX-4bit}"

# Source of truth for routing (set by scripts/agent-bench). If present, picks
# (model, max_tokens) per task; otherwise falls back to in-script defaults.
ROUTING_FILE="$STATE_DIR/routing.json"

# State files written during a run
LOCK_FILE="$STATE_DIR/lock"
ACTIVE_FILE="$STATE_DIR/active.json"
LOG_FILE="$STATE_DIR/log.jsonl"

JQ=/opt/homebrew/bin/jq

# Resolve API key (passthrough mode forwards the client key to omlx as Bearer).
# Strips surrounding single/double quotes and trailing CR (Windows-edited .env)
# so a quoted value doesn't reach curl as `Authorization: Bearer "value"`.
resolve_key() {
    if [ -n "${OMLX_API_KEY:-}" ]; then
        printf '%s' "$OMLX_API_KEY"
        return
    fi
    if [ -f "$PROJECT_DIR/.env" ]; then
        awk -F= '/^OMLX_API_KEY=/{
            v = $0; sub(/^OMLX_API_KEY=/, "", v);
            sub(/\r$/, "", v);
            gsub(/^["\047]|["\047]$/, "", v);
            print v; exit
        }' "$PROJECT_DIR/.env"
    fi
}

# Per-task routing override from bench results — single jq invocation.
# Returns:
#   default model name → keep DEFAULT (no qualitative win to switch)
#   picked model name  → switch (default fails, picked passes 100%)
# Ignores marginal latency advantages. ~25 ms instead of ~75 ms per call.
resolve_model_for_task() {
    local task="$1"
    [ ! -f "$ROUTING_FILE" ] && { printf '%s' "$MODEL"; return; }
    $JQ -r --arg m "$MODEL" --arg t "$task" '
        (.routes[$t]) as $r
        | if $r == null then $m
          elif $r.model == $m then $m
          else
            ([.routes[$t] | select(.picked_from | index($m))] | first | .pass_rate // 0) as $dp
            | if ($dp < 1.0) and (($r.pass_rate // 0) >= 0.99) then $r.model else $m end
          end
    ' "$ROUTING_FILE" 2>/dev/null || printf '%s' "$MODEL"
}

# Inspect parent process / env to fingerprint the calling Claude Code session
parent_context() {
    local ppid_chain cwd parent_cmd
    ppid_chain=$(/bin/ps -o ppid= -p $$ 2>/dev/null | /usr/bin/tr -d ' ')
    cwd=$(/bin/pwd)
    parent_cmd=$(/bin/ps -o command= -p "$ppid_chain" 2>/dev/null | /usr/bin/cut -c1-80)
    $JQ -n \
        --arg cwd "$cwd" \
        --arg ppid "$ppid_chain" \
        --arg pcmd "$parent_cmd" \
        --arg session "${CLAUDE_SESSION_ID:-${CLAUDECODE_SESSION_ID:-}}" \
        '{cwd:$cwd, ppid:$ppid, parent_cmd:$pcmd, session_id:$session}'
}

# Atomic-ish active.json writer
write_active() {
    local payload="$1"
    /bin/mkdir -p "$STATE_DIR"
    printf '%s\n' "$payload" > "$ACTIVE_FILE.tmp" && /bin/mv "$ACTIVE_FILE.tmp" "$ACTIVE_FILE"
}

clear_active() {
    /bin/rm -f "$ACTIVE_FILE" 2>/dev/null
}

append_log() {
    local payload="$1"
    /bin/mkdir -p "$STATE_DIR"
    # Single-printf write to keep the log.jsonl invariant under SIGKILL:
    # one JSON object + trailing newline must land in one syscall, not two.
    # The previous "compact then echo \n" pattern left half-written records
    # that the /internal/admin/agents handler couldn't decode.
    printf '%s\n' "$(printf '%s' "$payload" | $JQ -c .)" >> "$LOG_FILE"
}

# Task definitions are read from config/agents/tasks.json — single source
# of truth shared with scripts/agent-bench. To add a new task: edit the
# JSON; both scripts re-read on every invocation.
task_config() {
    local task="$1"
    local row
    row=$($JQ -r --arg t "$task" '.tasks[$t] // empty | "\(.max_tokens)\t\(.system)"' "$TASKS_JSON" 2>/dev/null)
    [ -z "$row" ] && return 1
    MAX_TOKENS="${row%%$'\t'*}"
    SYSTEM="${row#*$'\t'}"
}

cmd_tasks() {
    printf 'Available tasks (from %s):\n\n' "${TASKS_JSON#$PROJECT_DIR/}"
    # Pretty-print each task as: id (Nt) — first sentence of system prompt
    $JQ -r '
      .tasks
      | to_entries
      | sort_by(.key)[]
      | "  \(.key)  \"  \(.value.max_tokens)t  \"  \(.value.system | split(". ")[0] | .[0:80])"
    ' "$TASKS_JSON" | /usr/bin/awk -F'"' '{ printf "  %-22s %5s  %s\n", $1, $2, $3 }'
    printf '\nUsage: echo "<input>" | scripts/agent run <task>\n'
}

cmd_run() {
    local task="${1:-}"
    [ -z "$task" ] && { echo "usage: scripts/agent run <task>" >&2; exit 2; }

    if ! task_config "$task"; then
        echo "unknown task: $task" >&2
        echo "see: scripts/agent tasks" >&2
        exit 2
    fi

    local input
    if [ -t 0 ]; then
        echo "scripts/agent: no input on stdin" >&2
        echo "usage: echo \"<input>\" | scripts/agent run $task" >&2
        exit 2
    fi
    input=$(cat)

    local key
    key=$(resolve_key)
    [ -z "$key" ] && { echo "OMLX_API_KEY not found in env or .env" >&2; exit 3; }

    # Pick model based on bench results (default unless qualitative win)
    local picked_model
    picked_model=$(resolve_model_for_task "$task")

    # Acquire lock — portable across Linux/macOS via atomic mkdir.
    # Stale-lock guard requires THREE conditions (don't reclaim a live lock):
    #   1. lock dir's mtime > 5 min ago
    #   2. active.json has a parseable, non-zero pid
    #   3. that pid is gone (kill -0 fails)
    # The previous version reclaimed when active.json was missing or had no
    # pid — but a fresh holder may have just mkdir'd before writing
    # active.json, so we'd kill an in-flight sibling.
    /bin/mkdir -p "$STATE_DIR"
    if ! /bin/mkdir "$LOCK_FILE.d" 2>/dev/null; then
        local lock_age stale_pid
        # macOS stat -f, Linux stat -c — try both
        lock_age=$(( $(/bin/date +%s) - $( /usr/bin/stat -f %m "$LOCK_FILE.d" 2>/dev/null \
                                       || /usr/bin/stat -c %Y "$LOCK_FILE.d" 2>/dev/null \
                                       || echo 0) ))
        stale_pid=$($JQ -r '.pid // empty' "$ACTIVE_FILE" 2>/dev/null || true)
        if [ "$lock_age" -gt 300 ] \
           && [ -n "$stale_pid" ] \
           && [ "$stale_pid" -gt 0 ] 2>/dev/null \
           && ! /bin/kill -0 "$stale_pid" 2>/dev/null; then
            /bin/rm -rf "$LOCK_FILE.d" 2>/dev/null
            /bin/rm -f  "$ACTIVE_FILE" 2>/dev/null
            /bin/mkdir  "$LOCK_FILE.d" 2>/dev/null || { echo "[agent] couldn't reclaim stale lock" >&2; exit 7; }
        else
            local current_task
            current_task=$($JQ -r '.task // "unknown"' "$ACTIVE_FILE" 2>/dev/null || echo "unknown")
            echo "[agent] busy: another task ($current_task) is running" >&2
            exit 7
        fi
    fi
    # Lock acquired — make sure it's released on any exit
    trap '/bin/rm -rf "$LOCK_FILE.d" 2>/dev/null; clear_active' EXIT INT TERM

    # Write active.json so statusline + console can show what's running
    local started_at started_epoch ctx
    started_at=$(/bin/date +"%Y-%m-%dT%H:%M:%S")
    started_epoch=$(/bin/date +%s)
    ctx=$(parent_context)
    local prompt_preview
    prompt_preview=$(printf '%s' "$input" | /usr/bin/head -c 80 | /usr/bin/tr '\n' ' ')

    write_active "$($JQ -n \
        --arg task "$task" \
        --arg model "$picked_model" \
        --argjson mt "$MAX_TOKENS" \
        --arg started "$started_at" \
        --argjson started_epoch "$started_epoch" \
        --arg pid "$$" \
        --arg preview "$prompt_preview" \
        --argjson ctx "$ctx" \
        '{task:$task, model:$model, max_tokens:$mt, started_at:$started, started_epoch:$started_epoch, pid:$pid, prompt_preview:$preview, parent:$ctx}')"

    # active.json + lock cleanup is set in the lock-acquire trap above

    local body resp body_only http_code text stop in_tok out_tok dt
    body=$($JQ -n \
        --arg model "$picked_model" \
        --argjson mt "$MAX_TOKENS" \
        --arg sys "$SYSTEM" \
        --arg user "$input" \
        '{model:$model, max_tokens:$mt, temperature:0.2, chat_template_kwargs:{enable_thinking:false}, system:$sys, messages:[{role:"user", content:$user}]}')

    local t0=$(/usr/bin/python3 -c 'import time;print(time.time())')
    resp=$(/usr/bin/curl -s --max-time "$TIMEOUT" \
        -w "\n__HTTP__%{http_code}" \
        -X POST "$GATEII_URL/v1/messages" \
        -H "Content-Type: application/json" \
        -H "x-api-key: $key" \
        -H "x-provider: omlx" \
        -d "$body" 2>&1) || {
            echo "[agent] curl failed (timeout or network)" >&2
            append_log "$($JQ -n --arg t "$task" --arg m "$picked_model" --arg s "$started_at" \
                '{started_at:$s, task:$t, model:$m, error:"curl failed", exit:4}')"
            exit 4
        }
    local t1=$(/usr/bin/python3 -c 'import time;print(time.time())')
    dt=$(/usr/bin/python3 -c "print(round($t1-$t0,3))")

    http_code=$(printf '%s' "$resp" | /usr/bin/grep -oE '__HTTP__[0-9]+$' | /usr/bin/grep -oE '[0-9]+$' || echo "?")
    body_only=$(printf '%s' "$resp" | /usr/bin/sed 's/__HTTP__[0-9]*$//')

    if [ "$http_code" != "200" ]; then
        echo "[agent] upstream returned HTTP $http_code:" >&2
        echo "$body_only" >&2
        append_log "$($JQ -n --arg t "$task" --arg m "$picked_model" --arg s "$started_at" \
            --argjson dt "$dt" --argjson http "${http_code:-0}" \
            '{started_at:$s, task:$t, model:$m, latency_s:$dt, http:$http, exit:5}')"
        exit 5
    fi

    text=$(printf '%s' "$body_only" | $JQ -r '.content[0].text // ""')
    stop=$(printf '%s' "$body_only" | $JQ -r '.stop_reason // "?"')
    in_tok=$(printf '%s' "$body_only" | $JQ -r '
        (.usage.input_tokens // 0)
      + (.usage.cache_creation_input_tokens // 0)
      + (.usage.cache_read_input_tokens // 0)')
    out_tok=$(printf '%s' "$body_only" | $JQ -r '.usage.output_tokens // 0')

    if [ -z "$text" ]; then
        echo "[agent] empty response from omlx (stop=$stop)" >&2
        append_log "$($JQ -n --arg t "$task" --arg m "$picked_model" --arg s "$started_at" \
            --argjson dt "$dt" --arg stop "$stop" \
            '{started_at:$s, task:$t, model:$m, latency_s:$dt, stop:$stop, exit:6, error:"empty response"}')"
        exit 6
    fi

    # Append history record
    append_log "$($JQ -n \
        --arg s "$started_at" \
        --arg t "$task" \
        --arg m "$picked_model" \
        --argjson dt "$dt" \
        --arg stop "$stop" \
        --argjson in_tok "$in_tok" \
        --argjson out_tok "$out_tok" \
        --arg preview "$prompt_preview" \
        --arg out "$(printf '%s' "$text" | /usr/bin/head -c 300)" \
        '{started_at:$s, task:$t, model:$m, latency_s:$dt, stop:$stop, tokens_in:$in_tok, tokens_out:$out_tok, prompt_preview:$preview, output_preview:$out, exit:0}')"

    # Print result to stdout
    printf '%s\n' "$text"
}

cmd_list() {
    if [ -f "$ACTIVE_FILE" ]; then
        local now elapsed task model started preview pid
        now=$(/bin/date +%s)
        task=$($JQ -r '.task' "$ACTIVE_FILE")
        model=$($JQ -r '.model' "$ACTIVE_FILE")
        started=$($JQ -r '.started_epoch' "$ACTIVE_FILE")
        preview=$($JQ -r '.prompt_preview' "$ACTIVE_FILE")
        pid=$($JQ -r '.pid' "$ACTIVE_FILE")
        elapsed=$((now - started))
        printf "RUNNING  pid=%s  %s  via %s  (%ds)\n  → %s\n\n" "$pid" "$task" "$model" "$elapsed" "$preview"
    else
        printf "RUNNING  (none)\n\n"
    fi
    if [ -s "$LOG_FILE" ]; then
        printf "RECENT (last 10):\n"
        /usr/bin/tail -10 "$LOG_FILE" | $JQ -r '
            "  \(.started_at)  \(.task // "?")  \(.model // "?")  \(.latency_s // 0)s  exit=\(.exit // "?")"'
    else
        printf "RECENT  (no history)\n"
    fi
}

cmd_count_tokens() {
    # POST /v1/messages/count_tokens — no model invocation, just the tokenizer.
    # Uses default model unless --model passed. Reads stdin as the user content.
    local model="$MODEL"
    if [ "${1:-}" = "--model" ] && [ -n "${2:-}" ]; then
        model="$2"; shift 2
    fi
    if [ -t 0 ]; then
        echo "scripts/agent count-tokens: no input on stdin" >&2
        echo "usage: cat file.md | scripts/agent count-tokens [--model <id>]" >&2
        exit 2
    fi
    local input key body resp http_code body_only count
    input=$(cat)
    key=$(resolve_key)
    body=$($JQ -n --arg model "$model" --arg user "$input" \
        '{model:$model, messages:[{role:"user", content:$user}]}')
    resp=$(/usr/bin/curl -s --max-time "$TIMEOUT" \
        -w "\n__HTTP__%{http_code}" \
        -X POST "$GATEII_URL/v1/messages/count_tokens" \
        -H "Content-Type: application/json" \
        -H "x-api-key: $key" \
        -H "x-provider: omlx" \
        -d "$body")
    http_code=$(printf '%s' "$resp" | /usr/bin/grep -oE '__HTTP__[0-9]+$' | /usr/bin/grep -oE '[0-9]+$' || echo "?")
    body_only=$(printf '%s' "$resp" | /usr/bin/sed 's/__HTTP__[0-9]*$//')
    if [ "$http_code" != "200" ]; then
        echo "[agent] HTTP $http_code: $body_only" >&2
        exit 5
    fi
    count=$(printf '%s' "$body_only" | $JQ -r '.input_tokens // .count // 0')
    printf '%s\n' "$count"
}

case "${1:-}" in
    run)            shift; cmd_run "$@" ;;
    tasks)          cmd_tasks ;;
    list)           cmd_list ;;
    count-tokens)   shift; cmd_count_tokens "$@" ;;
    -h|--help|"")   cmd_tasks ;;
    *)              echo "unknown subcommand: $1 (try: tasks)" >&2; exit 2 ;;
esac
