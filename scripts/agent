#!/bin/bash
# scripts/agent — local omlx-backed task runner
#
# Routes simple tasks (commit messages, summaries, classification, etc.) to a
# local Qwen3.5-9B model via gateii → omlx, instead of burning Claude API
# tokens on them. Parent Claude Code calls this via Bash() when CLAUDE.md
# routing rules match.
#
# Usage:
#   echo "<input>" | scripts/agent run <task>
#   scripts/agent tasks                    # list available tasks
#   scripts/agent list                     # show running + recent (Stage 2)
#
# All tasks share these defaults:
#   - model: Qwen3.5-9B-MLX-4bit
#   - chat_template_kwargs: enable_thinking=false
#   - temperature: 0.2 (deterministic)
#   - timeout: 60s
#
# Routing path:
#   scripts/agent → gateii :8888 (x-provider:omlx) → omlx :8000 → Qwen3.5-9B
#
# State (Stage 2+):
#   data/agents/active.json   currently-running agents
#   data/agents/log.jsonl     append-only history
#   data/agents/lock          flock for concurrency=1

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$PROJECT_DIR/data/agents"
TASKS_JSON="$PROJECT_DIR/config/agents/tasks.json"

GATEII_URL="${GATEII_URL:-http://localhost:8888}"
TIMEOUT="${OMLX_AGENT_TIMEOUT:-60}"
MODEL="${OMLX_AGENT_MODEL:-Qwen3.5-9B-MLX-4bit}"

# Source of truth for routing (set by scripts/agent-bench). If present, picks
# (model, max_tokens) per task; otherwise falls back to in-script defaults.
ROUTING_FILE="$STATE_DIR/routing.json"

# State files written during a run
LOCK_FILE="$STATE_DIR/lock"
ACTIVE_FILE="$STATE_DIR/active.json"
LOG_FILE="$STATE_DIR/log.jsonl"

JQ=/opt/homebrew/bin/jq

# Resolve API key (passthrough mode forwards the client key to omlx as Bearer).
# Strips surrounding single/double quotes and trailing CR (Windows-edited .env)
# so a quoted value doesn't reach curl as `Authorization: Bearer "value"`.
resolve_key() {
    if [ -n "${OMLX_API_KEY:-}" ]; then
        printf '%s' "$OMLX_API_KEY"
        return
    fi
    if [ -f "$PROJECT_DIR/.env" ]; then
        awk -F= '/^OMLX_API_KEY=/{
            v = $0; sub(/^OMLX_API_KEY=/, "", v);
            sub(/\r$/, "", v);
            gsub(/^["\047]|["\047]$/, "", v);
            print v; exit
        }' "$PROJECT_DIR/.env"
    fi
}

# Per-task routing override from bench results — single jq invocation.
# Returns:
#   default model name → keep DEFAULT (no qualitative win to switch)
#   picked model name  → switch (default fails, picked passes 100%)
# Ignores marginal latency advantages. ~25 ms instead of ~75 ms per call.
resolve_model_for_task() {
    local task="$1"
    [ ! -f "$ROUTING_FILE" ] && { printf '%s' "$MODEL"; return; }
    $JQ -r --arg m "$MODEL" --arg t "$task" '
        (.routes[$t]) as $r
        | if $r == null then $m
          elif (($r.pass_rate // 0) >= 0.99) then $r.model
          else $m
          end
    ' "$ROUTING_FILE" 2>/dev/null || printf '%s' "$MODEL"
}

# Inspect parent process / env to fingerprint the calling Claude Code session
parent_context() {
    local ppid_chain cwd parent_cmd
    ppid_chain=$(/bin/ps -o ppid= -p $$ 2>/dev/null | /usr/bin/tr -d ' ')
    cwd=$(/bin/pwd)
    parent_cmd=$(/bin/ps -o command= -p "$ppid_chain" 2>/dev/null | /usr/bin/cut -c1-80)
    $JQ -n \
        --arg cwd "$cwd" \
        --arg ppid "$ppid_chain" \
        --arg pcmd "$parent_cmd" \
        --arg session "${CLAUDE_SESSION_ID:-${CLAUDECODE_SESSION_ID:-}}" \
        '{cwd:$cwd, ppid:$ppid, parent_cmd:$pcmd, session_id:$session}'
}

# Atomic-ish active.json writer
write_active() {
    local payload="$1"
    /bin/mkdir -p "$STATE_DIR"
    printf '%s\n' "$payload" > "$ACTIVE_FILE.tmp" && /bin/mv "$ACTIVE_FILE.tmp" "$ACTIVE_FILE"
}

clear_active() {
    /bin/rm -f "$ACTIVE_FILE" 2>/dev/null
}

append_log() {
    local payload="$1"
    /bin/mkdir -p "$STATE_DIR"
    local line
    line=$(printf '%s' "$payload" | $JQ -c .) || return 0
    # Serialize appends across cmd_run + cmd_feedback + a second session via a
    # short mkdir spinlock (portable — no flock on macOS). Without it, a record
    # larger than the stdio buffer splits into multiple write() syscalls that
    # interleave with a concurrent appender and corrupt a line.
    local lock="$LOG_FILE.lock.d"
    # Function-scoped trap so a signal can't orphan the log lock. cmd_feedback
    # reaches append_log without the run lock's EXIT trap, so cover RETURN too.
    trap '/bin/rm -rf "$lock" 2>/dev/null' RETURN INT TERM
    # Keep spinning until we win the lock — never proceed unlocked (a forced
    # takeover would corrupt the concurrent appender's in-flight line).
    while ! /bin/mkdir "$lock" 2>/dev/null; do
        sleep 0.01
    done
    printf '%s\n' "$line" >> "$LOG_FILE"
    # Bound growth — keep the last 5000 records (trim with hysteresis so we
    # rewrite only occasionally, not on every append).
    local n
    n=$(/usr/bin/wc -l < "$LOG_FILE" 2>/dev/null || echo 0)
    if [ "$n" -gt 5500 ]; then
        /usr/bin/tail -n 5000 "$LOG_FILE" > "$LOG_FILE.trim" 2>/dev/null \
            && /bin/mv "$LOG_FILE.trim" "$LOG_FILE"
    fi
    /bin/rm -rf "$lock" 2>/dev/null
}

# Task definitions are read from config/agents/tasks.json — single source
# of truth shared with scripts/agent-bench. To add a new task: edit the
# JSON; both scripts re-read on every invocation.
task_config() {
    local task="$1"
    local row
    row=$($JQ -r --arg t "$task" '.tasks[$t] // empty | "\(.max_tokens)\t\(.system)\t\(.strip_fences // false)"' "$TASKS_JSON" 2>/dev/null)
    [ -z "$row" ] && return 1
    MAX_TOKENS="${row%%$'\t'*}"
    local rest="${row#*$'\t'}"
    STRIP_FENCES="${rest##*$'\t'}"
    SYSTEM="${rest%$'\t'*}"
}

cmd_tasks() {
    printf 'Available tasks (from %s):\n\n' "${TASKS_JSON#$PROJECT_DIR/}"
    # Pretty-print each task as: id (Nt) — first sentence of system prompt
    $JQ -r '
      .tasks
      | to_entries
      | sort_by(.key)[]
      | "  \(.key)  \"  \(.value.max_tokens)t  \"  \(.value.system | split(". ")[0] | .[0:80])"
    ' "$TASKS_JSON" | /usr/bin/awk -F'"' '{ printf "  %-22s %5s  %s\n", $1, $2, $3 }'
    printf '\nUsage: echo "<input>" | scripts/agent run <task>\n'
}

cmd_run() {
    local task="${1:-}"
    [ -z "$task" ] && { echo "usage: scripts/agent run <task>" >&2; exit 2; }

    if ! task_config "$task"; then
        echo "unknown task: $task" >&2
        echo "see: scripts/agent tasks" >&2
        exit 2
    fi

    local input
    if [ -t 0 ]; then
        echo "scripts/agent: no input on stdin" >&2
        echo "usage: echo \"<input>\" | scripts/agent run $task" >&2
        exit 2
    fi
    input=$(cat)

    local key
    key=$(resolve_key)
    [ -z "$key" ] && { echo "OMLX_API_KEY not found in env or .env" >&2; exit 3; }

    # Pick model based on bench results (default unless qualitative win)
    local picked_model
    picked_model=$(resolve_model_for_task "$task")

    # Acquire lock — portable across Linux/macOS via atomic mkdir.
    # The lock is held by a LIVE agent run only when ALL hold:
    #   1. lock dir's mtime > 5 min ago (protects a fresh holder that mkdir'd
    #      but hasn't written active.json yet — don't kill an in-flight sibling)
    #   2. active.json identifies an agent-run (kind=="agent-run")
    #   3. with a parseable, non-zero pid that is still alive (kill -0)
    # The kind check matters: active.json is also written by agent-bench and
    # compose-ctl. A live BENCH pid in active.json is not the agent-run lock
    # holder — keying only on the pid wedged a genuinely-stale lock as "busy"
    # for the bench's whole lifetime.
    /bin/mkdir -p "$STATE_DIR"
    if ! /bin/mkdir "$LOCK_FILE.d" 2>/dev/null; then
        local lock_age stale_pid stale_kind holder_alive=0
        # macOS stat -f, Linux stat -c — try both
        lock_age=$(( $(/bin/date +%s) - $( /usr/bin/stat -f %m "$LOCK_FILE.d" 2>/dev/null \
                                       || /usr/bin/stat -c %Y "$LOCK_FILE.d" 2>/dev/null \
                                       || echo 0) ))
        stale_kind=$($JQ -r '.kind // empty' "$ACTIVE_FILE" 2>/dev/null || true)
        stale_pid=$($JQ -r '.pid // empty' "$ACTIVE_FILE" 2>/dev/null || true)
        if [ "$stale_kind" = "agent-run" ] \
           && [ -n "$stale_pid" ] \
           && [ "$stale_pid" -gt 0 ] 2>/dev/null \
           && /bin/kill -0 "$stale_pid" 2>/dev/null; then
            holder_alive=1
        fi
        if [ "$lock_age" -gt 300 ] && [ "$holder_alive" -eq 0 ]; then
            /bin/rm -rf "$LOCK_FILE.d" 2>/dev/null
            /bin/rm -f  "$ACTIVE_FILE" 2>/dev/null
            /bin/mkdir  "$LOCK_FILE.d" 2>/dev/null || { echo "[agent] couldn't reclaim stale lock" >&2; exit 7; }
        else
            local current_task
            current_task=$($JQ -r '.task // "unknown"' "$ACTIVE_FILE" 2>/dev/null || echo "unknown")
            echo "[agent] busy: another task ($current_task) is running" >&2
            exit 7
        fi
    fi
    # Lock acquired — make sure it's released on any exit
    trap '/bin/rm -rf "$LOCK_FILE.d" 2>/dev/null; clear_active' EXIT INT TERM

    # Write active.json so statusline + console can show what's running
    local started_at started_epoch ctx
    started_at=$(/bin/date +"%Y-%m-%dT%H:%M:%S")
    started_epoch=$(/bin/date +%s)
    ctx=$(parent_context)
    local prompt_preview
    prompt_preview=$(printf '%s' "$input" | /usr/bin/head -c 80 | /usr/bin/tr '\n' ' ')

    write_active "$($JQ -n \
        --arg kind "agent-run" \
        --arg task "$task" \
        --arg model "$picked_model" \
        --argjson mt "$MAX_TOKENS" \
        --arg started "$started_at" \
        --argjson started_epoch "$started_epoch" \
        --arg pid "$$" \
        --arg preview "$prompt_preview" \
        --argjson ctx "$ctx" \
        '{kind:$kind, task:$task, model:$model, max_tokens:$mt, started_at:$started, started_epoch:$started_epoch, pid:$pid, prompt_preview:$preview, parent:$ctx}')"

    # active.json + lock cleanup is set in the lock-acquire trap above

    local body resp body_only http_code text stop in_tok out_tok dt
    local t0=$(/usr/bin/python3 -c 'import time;print(time.time())')

    if [[ "$picked_model" == claude-* ]]; then
        # Claude CLI path — uses existing Claude Code auth (OAuth/proxy key).
        # Runs from /tmp so no project CLAUDE.md bleeds into the context.
        local claude_bin
        claude_bin=$(command -v claude 2>/dev/null || true)
        if [ -z "$claude_bin" ]; then
            echo "[agent] claude CLI not found — cannot route $task to $picked_model" >&2
            append_log "$($JQ -n --arg t "$task" --arg m "$picked_model" --arg s "$started_at" \
                '{started_at:$s, task:$t, model:$m, error:"claude CLI not found", exit:4}')"
            exit 4
        fi
        text=$(cd /tmp && "$claude_bin" \
            --model "$picked_model" \
            --print "$input" \
            --system-prompt "$SYSTEM" \
            --tools "" \
            --no-session-persistence \
            --output-format text \
            2>/dev/null) || true
        http_code=200; stop="end_turn"; in_tok=0; out_tok=0
    else
        # omlx path via gateii
        body=$($JQ -n \
            --arg model "$picked_model" \
            --argjson mt "$MAX_TOKENS" \
            --arg sys "$SYSTEM" \
            --arg user "$input" \
            '{model:$model, max_tokens:$mt, temperature:0.2, chat_template_kwargs:{enable_thinking:false}, system:$sys, messages:[{role:"user", content:$user}]}')

        resp=$(/usr/bin/curl -s --max-time "$TIMEOUT" \
            -w "\n__HTTP__%{http_code}" \
            -X POST "$GATEII_URL/v1/messages" \
            -H "Content-Type: application/json" \
            -H "x-api-key: $key" \
            -H "x-provider: omlx" \
            -d "$body" 2>&1) || {
                echo "[agent] curl failed (timeout or network)" >&2
                append_log "$($JQ -n --arg t "$task" --arg m "$picked_model" --arg s "$started_at" \
                    '{started_at:$s, task:$t, model:$m, error:"curl failed", exit:4}')"
                exit 4
            }

        http_code=$(printf '%s' "$resp" | /usr/bin/grep -oE '__HTTP__[0-9]+$' | /usr/bin/grep -oE '[0-9]+$' || echo "?")
        body_only=$(printf '%s' "$resp" | /usr/bin/sed 's/__HTTP__[0-9]*$//')
        # Numeric form for --argjson (jq rejects "?"/"" → would abort under set -e
        # before the intended exit 5). Keep $http_code for the human message.
        local http_num=${http_code//[!0-9]/}; http_num=${http_num:-0}

        if [ "$http_code" != "200" ]; then
            echo "[agent] upstream returned HTTP $http_code:" >&2
            echo "$body_only" >&2
            append_log "$($JQ -n --arg t "$task" --arg m "$picked_model" --arg s "$started_at" \
                --argjson dt "0" --argjson http "$http_num" \
                '{started_at:$s, task:$t, model:$m, latency_s:$dt, http:$http, exit:5}')"
            exit 5
        fi

        text=$(printf '%s' "$body_only" | $JQ -r '.content[0].text // ""')
        stop=$(printf '%s' "$body_only" | $JQ -r '.stop_reason // "?"')
        in_tok=$(printf '%s' "$body_only" | $JQ -r '
            (.usage.input_tokens // 0)
          + (.usage.cache_creation_input_tokens // 0)
          + (.usage.cache_read_input_tokens // 0)')
        out_tok=$(printf '%s' "$body_only" | $JQ -r '.usage.output_tokens // 0')
    fi

    local t1=$(/usr/bin/python3 -c 'import time;print(time.time())')
    dt=$(/usr/bin/python3 -c "print(round($t1-$t0,3))")

    # Strip markdown code fences if the task declares strip_fences=true.
    # Handles both ```lang\n...\n``` and ```\n...\n``` patterns. Needed because
    # some models (notably Haiku) wrap JSON/code in fences despite prompt instructions.
    if [ "$STRIP_FENCES" = "true" ] && [ -n "$text" ]; then
        text=$(printf '%s' "$text" | /usr/bin/sed -E 's/^```[a-z]*[[:space:]]*//' | /usr/bin/sed 's/[[:space:]]*```[[:space:]]*$//')
    fi

    if [ -z "$text" ]; then
        echo "[agent] empty response (model=$picked_model stop=$stop)" >&2
        append_log "$($JQ -n --arg t "$task" --arg m "$picked_model" --arg s "$started_at" \
            --argjson dt "$dt" --arg stop "$stop" \
            '{started_at:$s, task:$t, model:$m, latency_s:$dt, stop:$stop, exit:6, error:"empty response"}')"
        exit 6
    fi

    # Append history record
    append_log "$($JQ -n \
        --arg s "$started_at" \
        --arg t "$task" \
        --arg m "$picked_model" \
        --argjson dt "$dt" \
        --arg stop "$stop" \
        --argjson in_tok "$in_tok" \
        --argjson out_tok "$out_tok" \
        --arg preview "$prompt_preview" \
        --arg out "$(printf '%s' "$text" | /usr/bin/head -c 300)" \
        '{started_at:$s, task:$t, model:$m, latency_s:$dt, stop:$stop, tokens_in:$in_tok, tokens_out:$out_tok, prompt_preview:$preview, output_preview:$out, exit:0}')"

    # Print result to stdout
    printf '%s\n' "$text"
}

cmd_feedback() {
    # Record whether the last oMLX output was used as-is, lightly improved,
    # or fully replaced by Claude Code. Feeds production-vs-bench divergence
    # analysis in `scripts/agent stats`.
    local task="${1:-}"
    local verdict="${2:-}"
    local reason="${3:-}"
    [ -z "$task" ] || [ -z "$verdict" ] && {
        echo "usage: scripts/agent feedback <task> used|improved|replaced [reason]" >&2
        echo "  reason codes: format  content  length  capability" >&2
        exit 2
    }
    case "$verdict" in
        used|improved|replaced) ;;
        *) echo "verdict must be: used|improved|replaced" >&2; exit 2 ;;
    esac
    local model ts
    model=$(resolve_model_for_task "$task")
    ts=$(/bin/date +"%Y-%m-%dT%H:%M:%S")
    /bin/mkdir -p "$STATE_DIR"
    append_log "$($JQ -n \
        --arg s  "$ts" \
        --arg t  "$task" \
        --arg m  "$model" \
        --arg v  "$verdict" \
        --arg r  "$reason" \
        '{started_at:$s, task:$t, model:$m, log_type:"feedback", verdict:$v, reason:$r, exit:0}')"
}

cmd_stats() {
    # Correction-rate table: how often was oMLX output used/improved/replaced
    # per task in production. Correction rate = (improved+replaced)/total_feedback.
    # A rising corr% means the model or prompt needs work for that task.
    [ ! -f "$LOG_FILE" ] && { echo "No log data yet — run some tasks first."; exit 0; }
    /usr/bin/python3 - "$LOG_FILE" <<'PYEOF'
import sys, json, collections

log_file = sys.argv[1]
runs:     dict[str,int]                             = collections.defaultdict(int)
feedback: dict[str, dict[str,int]]                  = collections.defaultdict(lambda: collections.defaultdict(int))
reasons:  dict[str, dict[str,int]]                  = collections.defaultdict(lambda: collections.defaultdict(int))

with open(log_file) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            r = json.loads(line)
        except Exception:
            continue
        task = r.get("task", "")
        if not task or task == "bench-summary":
            continue
        if r.get("log_type") == "feedback":
            feedback[task][r.get("verdict", "unknown")] += 1
            if r.get("reason"):
                reasons[task][r["reason"]] += 1
        elif r.get("exit") == 0 and "latency_s" in r:
            runs[task] += 1

all_tasks = sorted(set(list(runs) + list(feedback)))
if not all_tasks:
    print("No task data in log yet.")
    sys.exit(0)

print(f"{'Task':<22} {'Runs':>6} {'Used':>6} {'Impr':>6} {'Repl':>6} {'OK%':>6} {'Corr%':>7}  Reasons")
print("─" * 90)
for task in all_tasks:
    n_runs = runs.get(task, 0)
    fb     = feedback.get(task, {})
    n_used = fb.get("used", 0)
    n_impr = fb.get("improved", 0)
    n_repl = fb.get("replaced", 0)
    n_fb   = n_used + n_impr + n_repl
    ok_s   = f"{int(n_used/n_fb*100)}%"  if n_fb else "—"
    corr_s = f"{int((n_impr+n_repl)/n_fb*100)}%" if n_fb else "—"
    top_reasons = ", ".join(
        f"{v}×{c}" for v, c in
        sorted(reasons.get(task, {}).items(), key=lambda x: -x[1])[:3]
    )
    print(f"{task:<22} {n_runs:>6} {n_used:>6} {n_impr:>6} {n_repl:>6} {ok_s:>6} {corr_s:>7}  {top_reasons}")

print()
print("Corr% = (improved+replaced) / total_feedback  →  rising = prompt or model needs work")
PYEOF
}

cmd_list() {
    if [ -f "$ACTIVE_FILE" ]; then
        local now elapsed task model started preview pid
        now=$(/bin/date +%s)
        task=$($JQ -r '.task // "?"' "$ACTIVE_FILE" 2>/dev/null || echo "?")
        model=$($JQ -r '.model // "?"' "$ACTIVE_FILE" 2>/dev/null || echo "?")
        # Guard started_epoch: a missing key yields literal "null" which aborts
        # the arithmetic under set -u; default to 0 and strip non-digits.
        started=$($JQ -r '.started_epoch // 0' "$ACTIVE_FILE" 2>/dev/null || echo 0)
        started=${started//[!0-9]/}; started=${started:-0}
        preview=$($JQ -r '.prompt_preview // ""' "$ACTIVE_FILE" 2>/dev/null || echo "")
        pid=$($JQ -r '.pid // "?"' "$ACTIVE_FILE" 2>/dev/null || echo "?")
        elapsed=$((now - started))
        printf "RUNNING  pid=%s  %s  via %s  (%ds)\n  → %s\n\n" "$pid" "$task" "$model" "$elapsed" "$preview"
    else
        printf "RUNNING  (none)\n\n"
    fi
    if [ -s "$LOG_FILE" ]; then
        printf "RECENT (last 10):\n"
        /usr/bin/tail -10 "$LOG_FILE" | $JQ -r '
            "  \(.started_at)  \(.task // "?")  \(.model // "?")  \(.latency_s // 0)s  exit=\(.exit // "?")"'
    else
        printf "RECENT  (no history)\n"
    fi
}

cmd_count_tokens() {
    # POST /v1/messages/count_tokens — no model invocation, just the tokenizer.
    # Uses default model unless --model passed. Reads stdin as the user content.
    local model="$MODEL"
    if [ "${1:-}" = "--model" ] && [ -n "${2:-}" ]; then
        model="$2"; shift 2
    fi
    if [ -t 0 ]; then
        echo "scripts/agent count-tokens: no input on stdin" >&2
        echo "usage: cat file.md | scripts/agent count-tokens [--model <id>]" >&2
        exit 2
    fi
    local input key body resp http_code body_only count
    input=$(cat)
    key=$(resolve_key)
    [ -z "$key" ] && { echo "OMLX_API_KEY not found in env or .env" >&2; exit 3; }
    body=$($JQ -n --arg model "$model" --arg user "$input" \
        '{model:$model, messages:[{role:"user", content:$user}]}')
    resp=$(/usr/bin/curl -s --max-time "$TIMEOUT" \
        -w "\n__HTTP__%{http_code}" \
        -X POST "$GATEII_URL/v1/messages/count_tokens" \
        -H "Content-Type: application/json" \
        -H "x-api-key: $key" \
        -H "x-provider: omlx" \
        -d "$body")
    http_code=$(printf '%s' "$resp" | /usr/bin/grep -oE '__HTTP__[0-9]+$' | /usr/bin/grep -oE '[0-9]+$' || echo "?")
    body_only=$(printf '%s' "$resp" | /usr/bin/sed 's/__HTTP__[0-9]*$//')
    if [ "$http_code" != "200" ]; then
        echo "[agent] HTTP $http_code: $body_only" >&2
        exit 5
    fi
    count=$(printf '%s' "$body_only" | $JQ -r '.input_tokens // .count // 0')
    printf '%s\n' "$count"
}

case "${1:-}" in
    run)            shift; cmd_run "$@" ;;
    feedback)       shift; cmd_feedback "$@" ;;
    stats)          cmd_stats ;;
    tasks)          cmd_tasks ;;
    list)           cmd_list ;;
    count-tokens)   shift; cmd_count_tokens "$@" ;;
    -h|--help|"")   cmd_tasks ;;
    *)              echo "unknown subcommand: $1 (try: tasks)" >&2; exit 2 ;;
esac
