#!/usr/bin/env python3
"""scripts/agent-bench — empirical task→model routing benchmark.

Self-adapts to the host: queries omlx /v1/models/status for available memory,
loads one model at a time when memory is tight, runs each task N times per
model, scores latency + format compliance, picks the best (model, max_tokens)
per task, and writes data/agents/routing.json for the wrapper to pick up.

Usage:
    scripts/agent-bench                        # full bench, default 3 trials
    scripts/agent-bench --trials 5             # more trials = lower variance
    scripts/agent-bench --quick                # 1 trial, default model only
    scripts/agent-bench --task TASK            # bench only one task (all models)
    scripts/agent-bench --model gemma-4-e2b    # bench all tasks for one model (substring match)
    scripts/agent-bench --task keywords --model gemma-4-e2b  # targeted single-cell re-bench

Outputs:
    data/agents/bench-results.json    raw per-trial data
    data/agents/bench-report.md       human-readable summary
    data/agents/routing.json          chosen model/max_tokens per task
"""
import argparse
import json
import os
import re
import shutil
import statistics
import subprocess
import sys
import time
import urllib.request
import urllib.error
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

ROOT      = Path(__file__).resolve().parent.parent
DATA_DIR  = ROOT / "data" / "agents"
ACTIVE    = DATA_DIR / "active.json"      # console reads this for the "running" card
# Cross-component bench lock. EXACT path is shared with scripts/compose-ctl.py
# (/run-bench) — both serialize on this same directory, so do not rename it.
BENCH_LOCK = DATA_DIR / "bench.lock.d"
BENCH_LOCK_STALE_S = 1800   # reclaim a lock dir older than 30 min (bench can run long)
TASKS_JSON= ROOT / "config" / "agents" / "tasks.json"
# Two upstream URLs:
#   OMLX_URL  — used for model management (/v1/models/status, /unload). gateii
#               doesn't proxy these admin paths, so we hit oMLX directly.
#   GATEII_URL — used for actual /v1/messages bench trials. Routes through the
#                gateii proxy so each trial is counted in the same per-user /
#                per-model metrics as wrapper invocations and surfaces broken
#                proxy state in the bench (single ingress).
OMLX_URL   = os.environ.get("OMLX_URL",   "http://localhost:8000")
GATEII_URL = os.environ.get("GATEII_URL", "http://localhost:8888")
RESERVE_GB = 4   # keep this much headroom on top of omlx's own max_model_memory

DEFAULT_MODEL = "Qwen3.5-9B-MLX-4bit"


def _load_env_key(var: str) -> str:
    env = ROOT / ".env"
    if env.exists():
        for line in env.read_text().splitlines():
            if line.startswith(var + "="):
                v = line.split("=", 1)[1].rstrip("\r").strip()
                if len(v) >= 2 and v[0] in '"\'' and v[-1] == v[0]:
                    v = v[1:-1]
                return v
    return os.environ.get(var, "")


def load_api_key() -> str:
    return _load_env_key("OMLX_API_KEY")


KEY = load_api_key()

# Direct-to-oMLX calls (model management): Bearer auth.
OMLX_HEADERS = {"Authorization": f"Bearer {KEY}", "Content-Type": "application/json"}
# Through-gateii calls (bench /v1/messages): client-key + x-provider header.
# In passthrough mode gateii forwards the key as-is to omlx and tags every
# request with provider="omlx" in metrics.
GATEII_HEADERS = {
    "x-api-key":     KEY,
    "x-provider":    "omlx",
    "Content-Type":  "application/json",
}

DEFAULT_REFERENCE_MODEL = "claude-haiku-4-5-20251001"
# Path to the claude CLI — uses existing Claude Code auth (OAuth/proxy), no
# separate ANTHROPIC_API_KEY needed.
CLAUDE_CLI = shutil.which("claude")


def http(method: str, path: str, body: dict | None = None,
         timeout: int = 120, via_gateii: bool = False):
    base    = GATEII_URL if via_gateii else OMLX_URL
    headers = GATEII_HEADERS if via_gateii else OMLX_HEADERS
    url  = base + path
    data = json.dumps(body).encode() if body else None
    req  = urllib.request.Request(url, method=method, data=data, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.status, json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        try:
            return e.code, json.loads(e.read().decode())
        except Exception:
            return e.code, {"error": str(e)}
    except Exception as e:
        return 0, {"error": str(e)}


# ─── locking & atomic writes ─────────────────────────────────────────────────
_HOLD_BENCH_LOCK = False  # True only between a successful acquire and its release


def acquire_bench_lock() -> None:
    """Serialize bench runs via an atomic mkdir lock (portable, no flock).
    Same convention as the scripts/agent run-lock: a lock dir older than
    BENCH_LOCK_STALE_S is treated as abandoned and reclaimed. The path is
    shared with scripts/compose-ctl.py /run-bench. Exits (without claiming
    ownership) if a live holder refuses to yield."""
    global _HOLD_BENCH_LOCK
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    try:
        os.mkdir(BENCH_LOCK)
        _HOLD_BENCH_LOCK = True
        return
    except FileExistsError:
        pass
    # Lock held — reclaim only if stale by mtime, else refuse.
    try:
        age = time.time() - os.path.getmtime(BENCH_LOCK)
    except OSError:
        age = 0
    if age > BENCH_LOCK_STALE_S:
        try:
            os.rmdir(BENCH_LOCK)
        except OSError:
            pass
        try:
            os.mkdir(BENCH_LOCK)
            _HOLD_BENCH_LOCK = True
            return
        except FileExistsError:
            pass  # someone else won the race — fall through to refuse
    sys.exit(f"another agent-bench run holds {BENCH_LOCK} "
             f"(age {int(age)}s; stale after {BENCH_LOCK_STALE_S}s) — refusing to clobber its writes")


def release_bench_lock() -> None:
    """Remove the lock dir only if THIS process acquired it — never delete a
    lock we failed to claim (that would clobber the live holder)."""
    global _HOLD_BENCH_LOCK
    if not _HOLD_BENCH_LOCK:
        return
    try:
        os.rmdir(BENCH_LOCK)
    except OSError:
        pass
    _HOLD_BENCH_LOCK = False


def _atomic_write(path: Path, content: str) -> None:
    """Write content to a temp file then os.replace into place — concurrent
    readers never observe a half-written file."""
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(content)
    os.replace(tmp, path)


# ─── task definitions ────────────────────────────────────────────────────────
# Single source of truth: config/agents/tasks.json (shared with scripts/agent).
# Each task contains: max_tokens, system, bench_prompt, compliant (regex string
# with inline flag prefixes — (?s) for DOTALL, (?i) for IGNORECASE).
_FENCE_RE = re.compile(r"^```[a-z]*\s*|\s*```\s*$")


def _strip_fences(text: str) -> str:
    """Remove opening ```lang and closing ``` markers if present."""
    return _FENCE_RE.sub("", text).strip()


def _load_tasks() -> dict:
    if not TASKS_JSON.exists():
        sys.exit(f"task config not found at {TASKS_JSON} — install gateii completely")
    raw = json.loads(TASKS_JSON.read_text())
    out = {}
    for name, t in raw.get("tasks", {}).items():
        try:
            scoring = t.get("scoring", "text")
            # For tool_use_name scoring, compliant is a plain string (tool name), not a regex
            compliant = t["compliant"] if scoring == "tool_use_name" else re.compile(t["compliant"])
            out[name] = {
                "max_tokens":   int(t["max_tokens"]),
                "system":       t["system"],
                "prompt":       t["bench_prompt"],
                "scoring":      scoring,
                "compliant":    compliant,
                "strip_fences": bool(t.get("strip_fences", False)),
                "tools":        t.get("tools"),
            }
        except (KeyError, re.error) as e:
            sys.exit(f"tasks.json[{name}]: {e}")
    return out


TASKS = _load_tasks()


# ─── memory management ──────────────────────────────────────────────────────
def models_status():
    code, data = http("GET", "/v1/models/status")
    if code != 200:
        sys.exit(f"omlx /v1/models/status failed: {data}")
    return data


def gb(b): return b / (1024**3)


def _headroom_for(status: dict, model_id: str) -> int:
    """Bytes free for loading model_id, keeping RESERVE_GB headroom. If model_id
    is already counted in current_model_memory (loaded), the caller shouldn't
    use this — it's only meaningful for a model that isn't resident yet."""
    return (status["max_model_memory"]
            - status["current_model_memory"]
            - RESERVE_GB * 1024**3)


def ensure_model(model_id: str, status: dict) -> dict | None:
    """Load model_id; unload others if budget tight.

    Returns the updated status on success, or None if model_id cannot be made
    to fit even after evicting the default — the caller should then record this
    model's trials as skipped ("does not fit budget") so the report can tell
    can't-fit apart from wrong-output."""
    info = next((m for m in status["models"] if m["id"] == model_id), None)
    if not info:
        sys.exit(f"unknown model: {model_id}")

    if info["loaded"]:
        return status  # already loaded, nothing to do

    needed = info["estimated_size"]

    if needed > _headroom_for(status, model_id):
        # Free space: evict everything except the default model (which we want sticky)
        for m in status["models"]:
            if m["loaded"] and m["id"] != DEFAULT_MODEL and m["id"] != model_id:
                print(f"  ⤵ unload {m['id']} ({gb(m['estimated_size']):.1f}GB) to fit {model_id}", flush=True)
                http("POST", f"/v1/models/{m['id']}/unload")

        # oMLX unload may be async — poll status until RAM is actually reclaimed
        # (or a short timeout) before trusting the new headroom for the fit check.
        deadline = time.time() + 30
        status = models_status()
        while needed > _headroom_for(status, model_id) and time.time() < deadline:
            time.sleep(1)
            status = models_status()

        # Post-eviction fit re-check (eviction kept DEFAULT_MODEL resident).
        if needed > _headroom_for(status, model_id):
            default_loaded = any(
                m["loaded"] and m["id"] == DEFAULT_MODEL for m in status["models"]
            )
            if default_loaded and model_id != DEFAULT_MODEL:
                # Last resort: temporarily evict the default too, reload it after.
                print(f"  ⤵ temporarily unload {DEFAULT_MODEL} to fit {model_id} "
                      f"(will reload after)", flush=True)
                http("POST", f"/v1/models/{DEFAULT_MODEL}/unload")
                deadline = time.time() + 30
                status = models_status()
                while needed > _headroom_for(status, model_id) and time.time() < deadline:
                    time.sleep(1)
                    status = models_status()
            if needed > _headroom_for(status, model_id):
                print(f"  ✗ {model_id} ({gb(needed):.1f}GB) does not fit budget "
                      f"({gb(_headroom_for(status, model_id)):.1f}GB free) — skipping", flush=True)
                return None

    print(f"  ⤴ loading {model_id} ({gb(needed):.1f}GB) — first call will be slow", flush=True)
    # oMLX has no public /v1/models/<id>/load endpoint via Bearer auth, so we
    # trigger the load via a tiny throwaway request. omlx loads on first call.
    http("POST", "/v1/messages", {
        "model": model_id, "max_tokens": 1, "chat_template_kwargs": {"enable_thinking": False},
        "messages": [{"role": "user", "content": "."}]
    }, timeout=300)
    return models_status()


def unload_after_bench(model_id: str) -> None:
    """Drop a model from RAM after we're done benching it. Default model stays
    loaded — the wrapper hits it constantly. Big models (Qwen3.6-35B at 20 GB)
    leave a lot of headroom when freed; small ones (gemma-4-e2b at 3.5 GB) are
    cheap to reload anyway."""
    if model_id == DEFAULT_MODEL:
        return
    print(f"  ⤵ unload {model_id} (bench done; default stays loaded)", flush=True)
    http("POST", f"/v1/models/{model_id}/unload")


# ─── benchmark ──────────────────────────────────────────────────────────────
def _write_active(task_name: str, model: str, trial: int, max_trials: int) -> None:
    """Make the bench visible on /console/agents while it runs.
    Uses 'bench:' prefix so it's distinguishable from real wrapper runs.
    """
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    payload = {
        "kind": "bench",  # distinguishes from scripts/agent's kind=="agent-run"
        "task": f"bench:{task_name} ({trial}/{max_trials})",
        "model": model,
        "max_tokens": TASKS[task_name]["max_tokens"],
        "started_at": time.strftime("%Y-%m-%dT%H:%M:%S"),
        "started_epoch": int(time.time()),
        "pid": str(os.getpid()),
        "prompt_preview": TASKS[task_name]["prompt"][:80].replace("\n", " "),
        "parent": {"cwd": str(ROOT), "ppid": str(os.getppid()),
                   "parent_cmd": "scripts/agent-bench", "session_id": ""},
    }
    tmp = ACTIVE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(payload))
    tmp.replace(ACTIVE)


def _clear_active() -> None:
    """Remove active.json only if it still belongs to THIS bench process.

    active.json is shared with scripts/agent (kind=="agent-run"). If a wrapper
    run started during the bench's post-trials phase, it now owns active.json —
    blindly unlinking would wipe its live "running" indicator. Only delete when
    the file still carries this bench's own pid (and a bench: task / kind), and
    leave anything carrying a different kind or pid untouched."""
    try:
        info = json.loads(ACTIVE.read_text())
    except FileNotFoundError:
        return
    except Exception:
        # Unreadable/garbled — could be a half-written file from another writer;
        # leave it rather than risk deleting a live indicator.
        return
    is_ours = (
        str(info.get("pid")) == str(os.getpid())
        and (info.get("kind") == "bench"
             or str(info.get("task", "")).startswith("bench:"))
    )
    if not is_ours:
        return
    try:
        ACTIVE.unlink()
    except FileNotFoundError:
        pass


def skipped_records(model: str, tasks: list[str], trials: int, reason: str) -> list[dict]:
    """Synthesize stop=='skipped' records so a model we couldn't bench shows up
    in the report as skipped (with a reason) rather than silently absent. The
    output string carries the reason so the report distinguishes can't-fit from
    wrong-output. aggregate() drops these rows, so they don't pollute pass_rate."""
    out = []
    for task in tasks:
        for i in range(trials):
            out.append(dict(
                task=task, model=model, trial=i + 1,
                latency_s=0, http=-2, stop="skipped",
                tokens_in=0, tokens_out=0,
                compliant=False, output=f"(skipped: {reason})",
            ))
    return out


def call(model: str, task_name: str, trial: int, max_trials: int = 3,
         override_max_tokens: int | None = None) -> dict:
    t = TASKS[task_name]
    _write_active(task_name, model, trial, max_trials)
    body = {
        "model": model,
        "max_tokens": override_max_tokens if override_max_tokens is not None else t["max_tokens"],
        "temperature": 0.2,
        "chat_template_kwargs": {"enable_thinking": False},
        "system": t["system"],
        "messages": [{"role": "user", "content": t["prompt"]}],
    }
    if t["tools"]:
        body["tools"] = t["tools"]
    t0 = time.time()
    # Bench trials go THROUGH gateii so they're counted in metrics. Falls
    # back to direct oMLX when gateii is down (code==0) OR up-but-broken
    # (5xx, or 429 rate-limited) — those are gateii/proxy faults, not the
    # MODEL's, so retrying direct avoids polluting the model's pass_rate.
    # Bench still produces results, just won't appear in the per-user counters.
    code, resp = http("POST", "/v1/messages", body, timeout=180, via_gateii=True)
    if code == 0 or code >= 500 or code == 429:
        # gateii unreachable or proxy-side failure — retry direct so a broken
        # proxy isn't scored as a model failure
        print(f"    (gateii fault {code}; falling back to direct oMLX for {task_name}/{trial})", flush=True)
        code, resp = http("POST", "/v1/messages", body, timeout=180, via_gateii=False)
    dt = time.time() - t0

    text, stop, in_tok, out_tok = "", "?", 0, 0
    if code == 200 and "content" in resp:
        stop = resp.get("stop_reason", "?")
        u = resp.get("usage") or {}
        in_tok = (u.get("input_tokens", 0)
                  + u.get("cache_creation_input_tokens", 0)
                  + u.get("cache_read_input_tokens", 0))
        out_tok = u.get("output_tokens", 0)
        # Extract text from first text block; collect tool_use blocks for scoring
        for block in (resp["content"] or []):
            if block.get("type") == "text" and not text:
                text = block.get("text", "")
            elif block.get("type") == "tool_use":
                text = json.dumps({"name": block.get("name"), "input": block.get("input")})

    if t["scoring"] == "tool_use_name":
        # Check that any content block is a tool_use with the expected function name
        content = resp.get("content") or [] if code == 200 else []
        called = [b.get("name") for b in content if b.get("type") == "tool_use"]
        compliant = t["compliant"] in called
        output_str = json.dumps(called) if called else text[:300]
    else:
        text_strip = text.strip()
        if t["strip_fences"]:
            text_strip = _strip_fences(text_strip)
        compliant = bool(t["compliant"].match(text_strip))
        output_str = text_strip[:300]

    return dict(
        task=task_name, model=model, trial=trial,
        latency_s=round(dt, 3), http=code, stop=stop,
        tokens_in=in_tok, tokens_out=out_tok,
        compliant=compliant, output=output_str,
    )


def call_via_claude_code(model: str, task_name: str, trial: int,
                         max_trials: int = 3) -> dict:
    """Bench a reference model (e.g. claude-haiku) via the `claude` CLI.
    Uses existing Claude Code auth (OAuth/proxy key) — no ANTHROPIC_API_KEY
    needed. Runs from /tmp so no project CLAUDE.md bleeds into the context.

    Tool-call tasks (scoring=tool_use_name) are skipped — the CLI's --print
    mode doesn't expose raw tool_use blocks. Those tasks are oMLX-only."""
    t = TASKS[task_name]
    if t["scoring"] == "tool_use_name":
        return dict(
            task=task_name, model=model, trial=trial,
            latency_s=0, http=-2, stop="skipped",
            tokens_in=0, tokens_out=0,
            compliant=False, output="(skipped: tool_use_name not supported via claude CLI)",
        )
    # Skip _write_active — reference bench runs in parallel; concurrent threads
    # would race on the single active.json.tmp temp file. Status tracking is
    # informational-only and meaningless during parallel execution anyway.
    cmd = [
        CLAUDE_CLI, "--model", model,
        "--print", t["prompt"],
        "--system-prompt", t["system"],
        "--tools", "",
        "--no-session-persistence",
        "--output-format", "text",
    ]
    t0 = time.time()
    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=60, cwd="/tmp",
        )
        text = result.stdout.strip()
        rc = result.returncode
    except subprocess.TimeoutExpired:
        text, rc = "", -1
    except Exception as e:
        text, rc = "", -1
        print(f"    (claude CLI error: {e})", flush=True)
    dt = time.time() - t0

    text_strip = text.strip()
    if t["strip_fences"]:
        text_strip = _strip_fences(text_strip)
    compliant = bool(t["compliant"].match(text_strip))
    return dict(
        task=task_name, model=model, trial=trial,
        latency_s=round(dt, 3), http=200 if rc == 0 else rc, stop="end_turn" if rc == 0 else "error",
        tokens_in=0, tokens_out=0,
        compliant=compliant, output=text_strip[:300],
    )


def bench_model(model: str, tasks: list[str], trials: int,
                reference: bool = False,
                override_max_tokens: int | None = None) -> list[dict]:
    results = []
    _call = call_via_claude_code if reference else call
    for task in tasks:
        runs = []
        for i in range(trials):
            r = _call(model, task, i + 1, trials,
                      **({"override_max_tokens": override_max_tokens}
                         if override_max_tokens and not reference else {}))
            runs.append(r)
            if r.get("stop") == "skipped":
                print(f"    S {task:22s} trial {i+1}/{trials}  (skipped)", flush=True)
                continue
            mark  = "✓" if r["compliant"] else "✗"
            flags = ""
            if r.get("stop") == "length":
                flags += " TRUNC"
            if r.get("http", 200) not in (200, -2):
                flags += f" ERR={r['http']}"
            print(f"    {mark} {task:22s} trial {i+1}/{trials}  {r['latency_s']:>5.2f}s  out={r['tokens_out']}{flags}",
                  flush=True)
        # Per-task summary after all trials — shows fail preview for quick diagnosis
        real_runs   = [r for r in runs if r.get("stop") != "skipped"]
        skip_count  = len(runs) - len(real_runs)
        pass_count  = sum(1 for r in real_runs if r["compliant"])
        trunc_count = sum(1 for r in real_runs if r.get("stop") == "length")
        if skip_count == len(runs):
            print(f"      → all {trials} skipped (not supported by this runner)", flush=True)
        elif pass_count < len(real_runs):
            trunc_note   = f"  TRUNC={trunc_count}/{len(real_runs)}" if trunc_count else ""
            fail_preview = next((r["output"][:100] for r in real_runs if not r["compliant"]), "")
            print(f"      → {pass_count}/{len(real_runs)} passed{trunc_note}  first-fail: {fail_preview!r}",
                  flush=True)
        results.extend(runs)
    return results


def aggregate(results: list[dict]) -> dict:
    """Group by (task, model), compute pass-rate + latency + failure diagnostics."""
    by = {}
    for r in results:
        by.setdefault((r["task"], r["model"]), []).append(r)

    agg = {}
    for (task, model), runs in by.items():
        # Exclude skipped trials (tool-call tasks on reference models that don't
        # support raw tool_use introspection via the CLI)
        runs = [r for r in runs if r.get("stop") != "skipped"]
        if not runs:
            continue
        lats      = [r["latency_s"] for r in runs]
        out_toks  = [r["tokens_out"] for r in runs]
        passes    = sum(1 for r in runs if r["compliant"])
        truncs    = sum(1 for r in runs if r.get("stop") == "length")
        errors    = sum(1 for r in runs if r.get("http", 200) not in (200,))
        max_tok   = TASKS[task]["max_tokens"]
        # Capture up to 2 failing outputs for the report's failure-samples section
        fail_outputs = [
            {"output": r["output"], "stop": r.get("stop", "?")}
            for r in runs if not r["compliant"]
        ][:2]
        warm_lats = lats[1:] if len(lats) > 1 else lats
        agg.setdefault(task, {})[model] = dict(
            trials=len(runs),
            passes=passes,  # exact count — don't reconstruct from the rounded rate
            pass_rate=round(passes / len(runs), 2),
            latency_p50=round(statistics.median(lats), 2),
            latency_warm_p50=round(statistics.median(warm_lats), 2),
            latency_max=round(max(lats), 2),
            tokens_out_avg=round(statistics.mean(out_toks), 1),
            trunc_rate=round(truncs / len(runs), 2),
            error_rate=round(errors / len(runs), 2),
            # util%: how close avg output is to the max_tokens cap
            util_pct=round(statistics.mean(out_toks) / max_tok * 100, 0) if max_tok > 0 else 0,
            fail_outputs=fail_outputs,
        )
    return agg


def _reference_already_benched(prev: dict, model: str) -> bool:
    """Skip reference model if today's results already exist."""
    if not prev or "results" not in prev:
        return False
    today = time.strftime("%Y-%m-%d")
    return (prev.get("started_at", "")[:10] == today
            and any(r.get("model") == model for r in prev["results"]))


def pick_routing(agg: dict) -> dict:
    """For each task pick the best model.

    Local models (non claude-*) are preferred. If the best local consistently
    fails (pass_rate < 0.5) AND a reference model (claude-*) passes ≥ 99%,
    the reference model is written as the routing choice so the wrapper uses it.
    picked_from always lists only the local candidates that were tried.
    """
    routing = {}
    for task, models in agg.items():
        local  = {m: s for m, s in models.items() if not m.startswith("claude-")}
        claude = {m: s for m, s in models.items() if     m.startswith("claude-")}
        if not local:
            continue
        ranked = sorted(
            local.items(),
            key=lambda kv: (-kv[1]["pass_rate"], kv[1]["latency_p50"]),
        )
        best_model, best_stats = ranked[0]
        local_candidates = [m for m, _ in ranked]

        # Claude fallback: route to reference model only when locals consistently
        # fail. Threshold < 0.5 avoids triggering on marginal underperformance.
        if best_stats["pass_rate"] < 0.5 and claude:
            claude_ranked = sorted(
                claude.items(),
                key=lambda kv: (-kv[1]["pass_rate"], kv[1]["latency_p50"]),
            )
            best_claude, best_claude_stats = claude_ranked[0]
            if best_claude_stats["pass_rate"] >= 0.99:
                routing[task] = dict(
                    model=best_claude,
                    max_tokens=TASKS[task]["max_tokens"],
                    pass_rate=best_claude_stats["pass_rate"],
                    latency_p50=best_claude_stats["latency_p50"],
                    picked_from=local_candidates,
                )
                continue

        routing[task] = dict(
            model=best_model,
            max_tokens=TASKS[task]["max_tokens"],
            pass_rate=best_stats["pass_rate"],
            latency_p50=best_stats["latency_p50"],
            picked_from=local_candidates,
        )
    return routing


def render_report(agg: dict, routing: dict, started_at: str) -> str:
    out = [f"# Agent Bench Report — {started_at}", ""]

    out.append("## Per-task pass-rate × model")
    out.append("")
    out.append("| Task | Model | Pass | p50 | warm_p50 | max | out-avg/cap | util% | trunc% |")
    out.append("|---|---|---:|---:|---:|---:|---:|---:|---:|")
    for task in sorted(agg):
        max_tok = TASKS[task]["max_tokens"]
        for model, s in sorted(agg[task].items()):
            trunc_flag = " ⚠" if s["trunc_rate"] > 0 else ""
            warm_flag = " ↓" if s["latency_warm_p50"] < s["latency_p50"] else ""
            out.append(
                f"| {task} | {model} | {int(s['pass_rate']*100)}% "
                f"| {s['latency_p50']}s | {s['latency_warm_p50']}s{warm_flag}"
                f"| {s['latency_max']}s "
                f"| {s['tokens_out_avg']}/{max_tok} "
                f"| {int(s['util_pct'])}% "
                f"| {int(s['trunc_rate']*100)}%{trunc_flag} |"
            )
    out.append("")

    # Failures section — shows compliant pattern + first failing output side-by-side
    failures = [
        (task, model, s)
        for task in sorted(agg)
        for model, s in sorted(agg[task].items())
        if s["pass_rate"] < 1.0 and s["fail_outputs"]
    ]
    if failures:
        out.append("## Failure samples")
        out.append("")
        out.append("> `⚠ TRUNC` = hit max_tokens cap → increase max_tokens in tasks.json")
        out.append("> `stop=?` / `http!=200` = infrastructure error")
        out.append("")
        for task, model, s in failures:
            pattern = TASKS[task]["compliant"].pattern
            out.append(
                f"### {task} / {model}"
                f"  (pass={int(s['pass_rate']*100)}%  trunc={int(s['trunc_rate']*100)}%)"
            )
            out.append("```")
            out.append(f"pattern : {pattern}")
            for i, f in enumerate(s["fail_outputs"], 1):
                flag = " ⚠ TRUNC" if f["stop"] == "length" else f"  stop={f['stop']}"
                out.append(f"fail {i}{flag}: {f['output'][:200]!r}")
            out.append("```")
            out.append("")

    out.append("## Picked routing (data/agents/routing.json)")
    out.append("")
    out.append("| Task | Model | Pass | p50 |")
    out.append("|---|---|---:|---:|")
    for task in sorted(routing):
        r = routing[task]
        flag = " ★" if r["model"].startswith("claude-") else ""
        out.append(f"| {task} | {r['model']}{flag} | {int(r['pass_rate']*100)}% | {r['latency_p50']}s |")

    return "\n".join(out) + "\n"


def render_calibration_report(results: list[dict], started_at: str) -> str:
    """Analyse --calibrate run results and emit max_tokens recommendations."""
    import math
    CALIBRATE_MAX = 1024
    by: dict[str, dict[str, list]] = {}
    for r in results:
        by.setdefault(r["task"], {}).setdefault(r["model"], []).append(r)

    # Read context window limits from bench-results.json metadata if available
    ctx_windows: dict[str, int] = {}  # model → max_context_window (populated from oMLX status later)

    out = [f"# Calibration Report — {started_at}", "",
           "> Run with max_tokens=1024 to measure actual output length per task.",
           "> Recommendations help tune tasks.json max_tokens caps.", ""]
    out.append("| Task | Configured | Model | p50_in | p50_out | max_out | stop=length | ctx% | Advice |")
    out.append("|---|---:|---|---:|---:|---:|---:|---:|---|")

    recommendations: dict[str, int] = {}  # task → recommended max_tokens
    for task in sorted(by):
        configured = TASKS[task]["max_tokens"]
        for model, runs in sorted(by[task].items()):
            real = [r for r in runs if r.get("stop") != "skipped"]
            if not real:
                continue
            outs   = sorted(r["tokens_out"] for r in real)
            ins    = sorted(r.get("tokens_in", 0) for r in real)
            p50    = outs[len(outs) // 2]
            p50_in = ins[len(ins) // 2]
            maxo   = outs[-1]
            trunc  = sum(1 for r in real if r.get("stop") == "length")
            ratio  = p50 / configured if configured > 0 else 0
            ctx_w  = ctx_windows.get(model, 32768)
            ctx_pct = round((p50_in + p50) / ctx_w * 100, 1) if ctx_w else 0

            if trunc > 0 or maxo > configured:
                # Model wanted more tokens than the cap allows
                rec = math.ceil(maxo * 1.5 / 10) * 10
                advice = f"⚠ cap too low (model used {maxo}>{configured}) — bump to {rec}"
            elif ratio < 0.2:
                rec = max(30, math.ceil(p50 * 2.0 / 10) * 10)
                advice = f"✓ generous ({int(ratio*100)}% util) — could reduce to {rec}"
            else:
                rec = configured
                note = f" (stops naturally at cap)" if ratio > 0.85 else ""
                advice = f"✓ OK ({int(ratio*100)}% util{note})"

            out.append(f"| {task} | {configured} | {model} | {p50_in} | {p50} | {maxo} | {trunc}/{len(real)} | {ctx_pct}% | {advice} |")
            # Track the highest recommendation across models for this task
            recommendations[task] = max(recommendations.get(task, configured), rec)

    out.append("")
    changed = {t: r for t, r in recommendations.items() if r != TASKS[t]["max_tokens"]}
    if changed:
        out.append("## Suggested tasks.json changes")
        out.append("")
        for task in sorted(changed):
            out.append(f"- **{task}**: {TASKS[task]['max_tokens']} → **{changed[task]}**")
    else:
        out.append("_All tasks within acceptable range — no changes needed._")

    return "\n".join(out) + "\n"


# ─── auto-review ────────────────────────────────────────────────────────────
# After every bench run Haiku analyses failures, truncations, high-util cases,
# and model divergences. Output: data/agents/bench-review.{md,json}.

REVIEW_UTIL_THRESHOLD = 85  # util% at or above this gets reviewed even when passing

REVIEW_SYSTEM = """\
You are reviewing a benchmark result for an oMLX local LLM deployment on Apple Silicon.

oMLX context:
- API format: Anthropic /v1/messages
- Models: Qwen3.5-9B-MLX-4bit (fast, general-purpose), gemma-4-e2b-it-4bit (fast, 3.5 GB),
  gemma-4-26b-a4b-it-4bit (slow, 15 GB, strong reasoning), Qwen3.6-35B-A3B-4bit (20 GB, high RAM)
- All bench calls: temperature=0.2, chat_template_kwargs={"enable_thinking": false}
- Context window: 32768 tokens for all models

Given a task definition and one model's output, diagnose the issue and recommend the \
most impactful fix.

Output ONLY a valid JSON object — no markdown fences, no text outside the object:
{
  "root_cause": "one-line diagnosis",
  "fix_type": "system_prompt|bench_prompt|max_tokens|compliant_pattern|omlx_setting|model_capability_gap|none",
  "fix": "specific actionable change, empty string if fix_type is none or capability_gap",
  "confidence": "high|medium|low"
}

fix_type guide:
- system_prompt: the instruction needs rewording or a stronger format constraint
- bench_prompt: the test input doesn't represent real usage well
- max_tokens: cap is too low (output gets cut) or unnecessarily generous
- compliant_pattern: regex is too strict, too loose, or misses valid model variants
- omlx_setting: temperature / enable_thinking / tool schema design needs changing
- model_capability_gap: model fundamentally cannot do this task; route elsewhere
- none: working correctly (e.g. high util but stop=end_turn, output is complete)\
"""


def collect_review_candidates(results: list[dict], agg: dict) -> list[dict]:
    """Return one representative record per interesting (task, model) case.

    Covers: failures, truncations (stop=length), util >= REVIEW_UTIL_THRESHOLD
    while passing, and tasks where local models diverge (some pass, others fail).
    Infrastructure errors (http != 200) are excluded — those are not model issues.
    """
    seen: set[tuple] = set()

    def _add(record: dict, reason: str) -> bool:
        key = (record["task"], record["model"], reason)
        if key in seen:
            return False
        seen.add(key)
        candidates.append({**record, "_review_reason": reason})
        return True

    candidates: list[dict] = []

    # 1. Failures and truncations — skip infra errors and skipped tool-use records
    for r in results:
        if r.get("stop") in ("skipped",):
            continue
        if r.get("http", 200) != 200:
            continue
        if r.get("stop") == "length":
            _add(r, "truncation")
        elif not r["compliant"]:
            _add(r, "failure")

    # 2. High-util while passing (cap may be dangerously close to the natural length)
    for task, models in agg.items():
        for model, s in models.items():
            if (s["util_pct"] >= REVIEW_UTIL_THRESHOLD
                    and s["pass_rate"] == 1.0
                    and s["trunc_rate"] == 0.0):
                sample = next(
                    (r for r in results
                     if r["task"] == task and r["model"] == model
                     and r.get("stop") != "skipped" and r.get("http", 200) == 200),
                    None,
                )
                if sample:
                    _add(sample, "high_util")

    # 3. Divergence: task where ≥1 local model fails and ≥1 passes
    #    (reference/claude-* excluded — they're not the optimization target)
    by_task: dict[str, dict[str, float]] = {}
    for task, models in agg.items():
        for model, s in models.items():
            if not model.startswith("claude-"):
                by_task.setdefault(task, {})[model] = s["pass_rate"]
    for task, model_rates in by_task.items():
        rates = list(model_rates.values())
        if min(rates) < 1.0 and max(rates) == 1.0:
            for model, rate in model_rates.items():
                if rate < 1.0:
                    sample = next(
                        (r for r in results
                         if r["task"] == task and r["model"] == model
                         and not r["compliant"]
                         and r.get("stop") != "skipped"
                         and r.get("http", 200) == 200),
                        None,
                    )
                    if sample:
                        _add(sample, "divergence")

    return candidates


def review_candidate(candidate: dict) -> dict:
    """Call Haiku to analyse one bench record. Returns a structured finding dict."""
    t = TASKS[candidate["task"]]
    reason = candidate.get("_review_reason", "failure")
    max_tok = t["max_tokens"]
    out_tok = candidate.get("tokens_out", 0)
    util_pct = int(out_tok / max_tok * 100) if max_tok > 0 else 0

    input_text = (
        f"Task: {candidate['task']}\n"
        f"Review reason: {reason}\n"
        f"System prompt: {t['system']}\n"
        f"Bench input (first 400 chars): {t['prompt'][:400]}\n"
        f"Compliant pattern: {t['compliant'].pattern}\n"
        f"Configured max_tokens: {max_tok}\n"
        f"---\n"
        f"Model: {candidate['model']}\n"
        f"Output (first 400 chars): {candidate['output'][:400]!r}\n"
        f"Stop reason: {candidate.get('stop', '?')}\n"
        f"Tokens out: {out_tok}/{max_tok} (util={util_pct}%)\n"
        f"Compliant: {candidate['compliant']}"
    )
    cmd = [
        CLAUDE_CLI, "--model", "claude-haiku-4-5-20251001",
        "--print", input_text,
        "--system-prompt", REVIEW_SYSTEM,
        "--tools", "",
        "--no-session-persistence",
        "--output-format", "text",
    ]
    t0 = time.time()
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30, cwd="/tmp")
        text = result.stdout.strip()
    except Exception as exc:
        return _review_error(candidate, reason, f"call failed: {exc}", t0)

    dt = round(time.time() - t0, 2)
    clean = _strip_fences(text.strip())
    try:
        parsed = json.loads(clean)
    except Exception:
        # Haiku occasionally adds a sentence before the JSON — extract it
        m = re.search(r'\{[^{}]*"root_cause"[^{}]*\}', text, re.DOTALL)
        if m:
            try:
                parsed = json.loads(m.group())
            except Exception:
                parsed = {"root_cause": text[:200], "fix_type": "unknown",
                          "fix": "", "confidence": "low"}
        else:
            parsed = {"root_cause": text[:200], "fix_type": "unknown",
                      "fix": "", "confidence": "low"}

    return {
        "task":            candidate["task"],
        "model":           candidate["model"],
        "review_reason":   reason,
        "compliant":       candidate["compliant"],
        "output_sample":   candidate["output"][:200],
        "review":          parsed,
        "review_latency_s": dt,
        "reviewer":        "claude-haiku-4-5-20251001",
    }


def _review_error(candidate: dict, reason: str, msg: str, t0: float) -> dict:
    return {
        "task":            candidate["task"],
        "model":           candidate["model"],
        "review_reason":   reason,
        "compliant":       candidate["compliant"],
        "output_sample":   candidate["output"][:200],
        "review":          {"root_cause": msg, "fix_type": "none", "fix": "", "confidence": "low"},
        "review_latency_s": round(time.time() - t0, 2),
        "reviewer":        "claude-haiku-4-5-20251001",
    }


def render_review_report(reviews: list[dict], started_at: str) -> str:
    FIX_ORDER = [
        "system_prompt", "bench_prompt", "max_tokens", "compliant_pattern",
        "omlx_setting", "model_capability_gap", "none", "unknown",
    ]
    FIX_LABELS = {
        "system_prompt":        "System prompt change needed",
        "bench_prompt":         "Bench prompt change needed",
        "max_tokens":           "max_tokens adjustment needed",
        "compliant_pattern":    "Compliant pattern change needed",
        "omlx_setting":         "oMLX setting change needed",
        "model_capability_gap": "Model capability gap (route elsewhere)",
        "none":                 "No action needed",
        "unknown":              "Undetermined",
    }

    by_fix: dict[str, list] = {}
    for r in reviews:
        ft = r["review"].get("fix_type", "unknown")
        by_fix.setdefault(ft, []).append(r)

    out = [
        f"# oMLX Bench Review — {started_at}", "",
        "Haiku reviewed every failure, truncation, high-util, and divergence case.", "",
    ]

    actionable = [ft for ft in FIX_ORDER
                  if ft not in ("none", "unknown") and by_fix.get(ft)]
    if actionable:
        out.append("## Actionable findings")
        out.append("")
        for ft in actionable:
            out.append(f"### {FIX_LABELS[ft]}")
            for r in by_fix[ft]:
                rv = r["review"]
                conf = rv.get("confidence", "?")
                out.append(f"- **{r['task']}** / `{r['model']}` [{r['review_reason']}] conf={conf}")
                out.append(f"  - Cause: {rv.get('root_cause', '?')}")
                if rv.get("fix"):
                    out.append(f"  - Fix: {rv.get('fix')}")
            out.append("")

    if by_fix.get("none") or by_fix.get("unknown"):
        out.append("## No action needed")
        out.append("")
        for r in by_fix.get("none", []) + by_fix.get("unknown", []):
            rv = r["review"]
            out.append(f"- **{r['task']}** / `{r['model']}` [{r['review_reason']}]: {rv.get('root_cause', '?')}")
        out.append("")

    if not reviews:
        out.append("_No interesting cases — all tasks passing with comfortable margins._")

    return "\n".join(out)


# ─── main ───────────────────────────────────────────────────────────────────
def _load_existing_results():
    """Return previous bench-results.json (or {}) so --smart can skip cells."""
    p = DATA_DIR / "bench-results.json"
    if not p.exists():
        return {}
    try:
        return json.loads(p.read_text())
    except Exception:
        return {}


def _model_unchanged(prev: dict, model: str, created: int) -> bool:
    """True iff prev has results for this model AND its omlx-registration
    timestamp matches (so the model wasn't re-imported with new weights)."""
    if not prev or "results" not in prev:
        return False
    if (prev.get("model_created") or {}).get(model) != created:
        return False
    return any(r.get("model") == model for r in prev["results"])


# Backwards-compatible alias: carry-forward still asks "does prev cover this
# (unchanged) model at all?" per-record.
_models_already_benched = _model_unchanged


def _tasks_benched_for(prev: dict, model: str) -> set:
    """Set of task names for which prev has at least one (real, non-skipped)
    result for this model."""
    if not prev or "results" not in prev:
        return set()
    return {
        r["task"] for r in prev["results"]
        if r.get("model") == model and r.get("stop") != "skipped"
    }


def _missing_tasks(prev: dict, model: str, created: int, eligible: list[str]) -> list[str]:
    """Task-aware smart-skip: of this model's eligible tasks, which ones are NOT
    already covered by unchanged prev results. Empty list => fully cached (skip);
    a strict subset => bench only the gaps (e.g. a newly added task)."""
    if not _model_unchanged(prev, model, created):
        return list(eligible)
    done = _tasks_benched_for(prev, model)
    return [t for t in eligible if t not in done]


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--trials", type=int, default=3)
    ap.add_argument("--quick", action="store_true", help="1 trial, default model only")
    ap.add_argument("--task", help="bench only this task name")
    ap.add_argument("--force", action="store_true",
                    help="re-bench all models even if results exist (overrides --smart, the default)")
    ap.add_argument("--no-reference", action="store_true",
                    help="skip reference model (claude-haiku) even if claude CLI is available")
    ap.add_argument("--reference-model", default=DEFAULT_REFERENCE_MODEL,
                    help=f"reference model to bench (default: {DEFAULT_REFERENCE_MODEL})")
    ap.add_argument("--reference-only", action="store_true",
                    help="skip all oMLX models; bench only the reference model (no oMLX needed)")
    ap.add_argument("--model", dest="model_filter",
                    help="bench only models whose ID contains this substring (e.g. gemma-4-e2b)")
    ap.add_argument("--calibrate", action="store_true",
                    help="run each task with max_tokens=1024 to measure real output length; "
                         "writes bench-calibration.json + prints recommendations, skips routing update")
    ap.add_argument("--reference-trials", type=int, default=1,
                    help="number of trials for the reference model (default: 1; reference is "
                         "consistent and external — more trials waste API budget)")
    ap.add_argument("--analyze", action="store_true",
                    help="offline: read bench-results.json and re-run analysis + routing without "
                         "calling any models; useful for post-hoc re-scoring after tasks.json changes")
    ap.add_argument("--no-review", action="store_true",
                    help="skip auto-review pass (Haiku analysis of failures/high-util/divergences)")
    args = ap.parse_args()

    if args.reference_only and args.no_reference:
        sys.exit("--reference-only and --no-reference are mutually exclusive")

    # Serialize result writes against a concurrent run / compose-ctl /run-bench.
    # Held until the finally in __main__ releases it.
    acquire_bench_lock()

    # --analyze: offline re-score of existing bench-results.json, no model calls
    if args.analyze:
        res_path = DATA_DIR / "bench-results.json"
        if not res_path.exists():
            sys.exit(f"--analyze: {res_path} not found; run bench first")
        started = time.strftime("%Y-%m-%dT%H:%M:%S")
        print(f"agent-bench • {started} • --analyze (offline, no model calls)", flush=True)
        raw = json.loads(res_path.read_text())
        all_results = raw.get("results", [])
        # Re-score with current tasks.json compliant patterns (catches pattern fixes)
        for r in all_results:
            t = TASKS.get(r["task"])
            if not t or r.get("stop") == "skipped":
                continue
            if t.get("scoring") == "tool_use_name":
                continue  # tool_use scoring requires raw content blocks, skip re-scoring
            text = r.get("output", "")
            if t.get("strip_fences"):
                text = _strip_fences(text)
            r["compliant"] = bool(t["compliant"].match(text.strip()))
        agg = aggregate(all_results)
        routing = pick_routing(agg)
        routing_path = DATA_DIR / "routing.json"
        if routing_path.exists():
            existing = json.loads(routing_path.read_text()).get("routes", {})
            routing = {**existing, **routing}
        _atomic_write(DATA_DIR / "routing.json", json.dumps({
            "generated_at": started,
            "default_model": DEFAULT_MODEL,
            "routes": routing,
        }, indent=2) + "\n")
        report = render_report(agg, routing, started)
        _atomic_write(DATA_DIR / "bench-report.md", report)
        print("\n" + report, flush=True)
        print(f"\nWrote: routing.json, bench-report.md  (bench-results.json unchanged)", flush=True)
        print("EXIT: 0", flush=True)
        return

    if not args.reference_only and not KEY:
        sys.exit("OMLX_API_KEY not in env or .env")

    DATA_DIR.mkdir(parents=True, exist_ok=True)
    started = time.strftime("%Y-%m-%dT%H:%M:%S")
    tasks_full = [args.task] if args.task else list(TASKS.keys())
    if args.task and args.task not in TASKS:
        sys.exit(f"unknown task: {args.task}")

    all_results = []
    skipped: list[str] = []
    model_created: dict = {}
    prev = {} if (args.force or args.quick or args.task) else _load_existing_results()

    if args.reference_only:
        print(f"agent-bench • {started} • --reference-only (no oMLX needed)", flush=True)
    else:
        print(f"agent-bench • {started} • host={OMLX_URL}", flush=True)
        status = models_status()
        print(f"  RAM: {gb(status['current_model_memory']):.1f}/{gb(status['max_model_memory']):.1f} GB used, "
              f"{status['loaded_count']}/{status['model_count']} models loaded", flush=True)

        # Determine which models to bench
        available = [m["id"] for m in status["models"]]
        if args.quick:
            models_to_bench = [DEFAULT_MODEL]
        else:
            models_to_bench = [DEFAULT_MODEL]
            for m in available:
                if m != DEFAULT_MODEL:
                    models_to_bench.append(m)
        if args.model_filter:
            models_to_bench = [m for m in models_to_bench if args.model_filter in m]
            if not models_to_bench:
                sys.exit(f"--model {args.model_filter!r}: no matching models in oMLX (available: {available})")

        SMALL_MODEL_GB = 10
        sizes = {m["id"]: m["estimated_size"] for m in status["models"]}
        model_created = {m["id"]: m.get("created") or 0 for m in status["models"]}

        # Carry forward existing per-model results that we're choosing to skip.
        # Never carry forward a model that matches an explicit --model filter —
        # an explicit re-bench must replace its stale results, not keep them.
        if prev and prev.get("results"):
            for r in prev["results"]:
                if args.model_filter and args.model_filter in r["model"]:
                    continue
                if _models_already_benched(prev, r["model"], model_created.get(r["model"])):
                    all_results.append(r)

        for model in models_to_bench:
            size_gb = gb(sizes.get(model, 0))
            is_small = size_gb <= SMALL_MODEL_GB
            if model == DEFAULT_MODEL or args.task or args.quick or is_small:
                eligible = tasks_full
            else:
                eligible = [t for t in ["reasoning", "classify-yesno"] if t in tasks_full]
                if not eligible:
                    continue

            explicit = bool(args.model_filter and args.model_filter in model)
            if args.calibrate or explicit:
                # Calibration always re-runs; an explicit --model re-bench must
                # cover the model's full eligible set (its prev results were not
                # carried forward), so don't smart-skip either of these.
                tasks = eligible
            else:
                # Task-aware smart-skip: only the eligible tasks not already
                # covered by unchanged prev results. A newly added task to
                # tasks.json is benched even for otherwise-cached models.
                tasks = _missing_tasks(prev, model, model_created.get(model), eligible)
                if not tasks:
                    skipped.append(model)
                    print(f"\n=== {model} ({size_gb:.1f} GB) — SKIP (cached, all tasks covered, model unchanged; --force to override) ===", flush=True)
                    continue
                if len(tasks) < len(eligible):
                    print(f"\n=== {model} ({size_gb:.1f} GB) — partial: benching {len(tasks)} new/missing task(s), {len(eligible) - len(tasks)} cached ===", flush=True)

            size_label = f"{size_gb:.1f} GB" + (" — small, full bench" if (is_small and model != DEFAULT_MODEL) else "")
            print(f"\n=== {model} ({size_label}) — {len(tasks)} task(s) × {1 if args.quick else args.trials} trial(s) ===", flush=True)
            trials = 1 if args.quick else args.trials
            new_status = ensure_model(model, status)
            if new_status is None:
                # Couldn't make the model fit even after evicting the default —
                # record skipped trials so the report shows can't-fit, not absent.
                skipped.append(model)
                all_results.extend(skipped_records(model, tasks, trials, "does not fit budget"))
                status = models_status()  # refresh after the eviction attempts
                continue
            status = new_status
            all_results.extend(bench_model(
                model, tasks, trials,
                override_max_tokens=1024 if args.calibrate else None,
            ))
            unload_after_bench(model)
            status = models_status()
            # ensure_model may have temporarily evicted the default to fit a big
            # model — reload it so the wrapper isn't left with a cold default.
            if model != DEFAULT_MODEL and not any(
                m["loaded"] and m["id"] == DEFAULT_MODEL for m in status["models"]
            ):
                print(f"  ⤴ reloading {DEFAULT_MODEL} (was temporarily evicted)", flush=True)
                reloaded = ensure_model(DEFAULT_MODEL, status)
                status = reloaded if reloaded is not None else models_status()

    # Reference model bench (Claude Haiku via `claude` CLI).
    # Uses existing Claude Code auth — no ANTHROPIC_API_KEY needed.
    # Skipped for --quick, --no-reference, --model, --calibrate, or if claude CLI not on PATH.
    # Runs in parallel (ThreadPoolExecutor) since it's external — no GPU contention.
    # Default 1 trial (reference is consistent; extra trials waste API budget).
    ref_model = args.reference_model
    if CLAUDE_CLI and not args.no_reference and not args.quick and not args.model_filter and not args.calibrate:
        if _reference_already_benched(prev, ref_model) and not args.force:
            skipped.append(ref_model)
            print(f"\n=== {ref_model} (reference) — SKIP (already benched today; --force to override) ===",
                  flush=True)
        else:
            ref_tasks = tasks_full
            ref_trials = args.reference_trials
            print(f"\n=== {ref_model} (reference, via claude CLI) — "
                  f"{len(ref_tasks)} task(s) × {ref_trials} trial(s) [parallel] ===", flush=True)
            # Collect (task, trial_index) tuples for parallel dispatch
            ref_work = [(task, i + 1) for task in ref_tasks for i in range(ref_trials)]
            ref_raw: dict[tuple, dict] = {}
            with ThreadPoolExecutor(max_workers=3) as pool:
                futures = {
                    pool.submit(call_via_claude_code, ref_model, task, trial, ref_trials): (task, trial)
                    for task, trial in ref_work
                }
                for future in as_completed(futures):
                    key = futures[future]
                    try:
                        ref_raw[key] = future.result()
                    except Exception as exc:
                        ref_raw[key] = dict(
                            task=key[0], model=ref_model, trial=key[1],
                            latency_s=0, http=-3, stop="error",
                            tokens_in=0, tokens_out=0, compliant=False,
                            output=str(exc)[:200],
                        )
            # Emit per-trial progress lines in task order (parallel ran out-of-order)
            for task in ref_tasks:
                for trial in range(1, ref_trials + 1):
                    r = ref_raw.get((task, trial), {})
                    if r.get("stop") == "skipped":
                        print(f"    S {task:22s} trial {trial}/{ref_trials}  (skipped)", flush=True)
                        continue
                    mark  = "✓" if r.get("compliant") else "✗"
                    flags = " TRUNC" if r.get("stop") == "length" else ""
                    if r.get("http", 200) not in (200, -2):
                        flags += f" ERR={r.get('http')}"
                    print(f"    {mark} {task:22s} trial {trial}/{ref_trials}  {r.get('latency_s', 0):>5.2f}s  out={r.get('tokens_out', 0)}{flags}",
                          flush=True)
                # Per-task summary
                task_runs = [ref_raw[(task, t)] for t in range(1, ref_trials + 1)
                             if (task, t) in ref_raw and ref_raw[(task, t)].get("stop") != "skipped"]
                if task_runs:
                    pc = sum(1 for r in task_runs if r.get("compliant"))
                    if pc < len(task_runs):
                        fp = next((r["output"][:100] for r in task_runs if not r.get("compliant")), "")
                        print(f"      → {pc}/{len(task_runs)} passed  first-fail: {fp!r}", flush=True)
            all_results.extend(ref_raw.values())
        model_created[ref_model] = 0  # no omlx timestamp for Claude models
    elif not CLAUDE_CLI and not args.no_reference and not args.quick and not args.model_filter and not args.calibrate:
        print("\n  (reference model skipped — claude CLI not found on PATH)", flush=True)

    # Calibration path: emit recommendations, skip routing + bench-results update
    if args.calibrate:
        cal_report = render_calibration_report(all_results, started)
        (DATA_DIR / "bench-calibration.json").write_text(json.dumps({
            "started_at": started, "calibrate_max_tokens": 1024,
            "results": all_results,
        }, indent=2) + "\n")
        (DATA_DIR / "bench-calibration.md").write_text(cal_report)
        print("\n" + cal_report, flush=True)
        print(f"\nWrote: data/agents/bench-calibration.json, bench-calibration.md", flush=True)
        print("EXIT: 0", flush=True)
        return

    # Aggregate + decide
    agg = aggregate(all_results)
    routing = pick_routing(agg)

    # Merge new routing into existing for targeted runs (--task / --model / --reference-only).
    # Full bench replaces everything; targeted runs update only their cells.
    routing_path = DATA_DIR / "routing.json"
    is_targeted = args.task or args.model_filter or args.reference_only
    if is_targeted and routing_path.exists():
        try:
            existing_routes = json.loads(routing_path.read_text()).get("routes", {})
            merged = {**existing_routes, **routing}  # new cells overwrite; rest preserved
            if args.reference_only and not routing:
                merged = existing_routes
                print("  (reference-only: keeping existing routing.json unchanged)", flush=True)
            routing = merged
        except Exception:
            pass

    # Persist
    # For targeted runs (--task / --model), merge new results into existing bench-results.json
    # so we don't lose full-bench data. Full bench always overwrites.
    results_to_write = all_results
    if is_targeted:
        existing_path = DATA_DIR / "bench-results.json"
        if existing_path.exists():
            try:
                prev_data = json.loads(existing_path.read_text())
                benched_cells = {(r["task"], r["model"]) for r in all_results}
                kept = [r for r in prev_data.get("results", [])
                        if (r["task"], r["model"]) not in benched_cells]
                results_to_write = kept + all_results
            except Exception:
                pass
    # These three writes are guarded by the bench lock acquired in main(), so an
    # overlapping run can't interleave with them. Each is still written
    # atomically (tmp + os.replace) so a reader never sees a half-written file.
    results_path = DATA_DIR / "bench-results.json"
    if results_path.exists():  # keep one rolling backup before every overwrite
        try:
            results_path.replace(DATA_DIR / "bench-results.prev.json")
        except Exception:
            pass
    _atomic_write(results_path, json.dumps({
        "started_at": started,
        "started_epoch": int(time.time()),
        "host": OMLX_URL,
        "trials_per_cell": 1 if args.quick else args.trials,
        "model_created": model_created,
        "skipped_models": skipped,
        "results": results_to_write,
    }, indent=2) + "\n")
    _atomic_write(DATA_DIR / "routing.json", json.dumps({
        "generated_at": started,
        "default_model": DEFAULT_MODEL,
        "routes": routing,
    }, indent=2) + "\n")
    report = render_report(agg, routing, started)
    _atomic_write(DATA_DIR / "bench-report.md", report)

    print("\n" + report, flush=True)
    print(f"\nWrote: data/agents/bench-results.json, routing.json, bench-report.md", flush=True)

    # Auto-review: Haiku analyses failures, truncations, high-util, and divergences
    # in parallel. Produces bench-review.{md,json}. Skipped for --quick, --calibrate,
    # --no-review, or when claude CLI is not on PATH.
    if CLAUDE_CLI and not args.quick and not args.no_review:
        candidates = collect_review_candidates(all_results, agg)
        if candidates:
            print(f"\n=== Auto-review: {len(candidates)} case(s) → Haiku [parallel] ===", flush=True)
            reviews: list[dict] = []
            with ThreadPoolExecutor(max_workers=3) as pool:
                futures = {pool.submit(review_candidate, c): c for c in candidates}
                for future in as_completed(futures):
                    try:
                        reviews.append(future.result())
                    except Exception as exc:
                        pass
            # Sort findings: actionable first (by fix_type), then no-action
            FIX_PRIORITY = ["system_prompt", "bench_prompt", "max_tokens",
                            "compliant_pattern", "omlx_setting",
                            "model_capability_gap", "none", "unknown"]
            reviews.sort(key=lambda r: (
                FIX_PRIORITY.index(r["review"].get("fix_type", "unknown"))
                if r["review"].get("fix_type", "unknown") in FIX_PRIORITY else 99,
                r["task"],
            ))
            review_report = render_review_report(reviews, started)
            (DATA_DIR / "bench-review.md").write_text(review_report)
            (DATA_DIR / "bench-review.json").write_text(json.dumps({
                "reviewed_at": started,
                "candidates":  len(candidates),
                "reviews":     reviews,
            }, indent=2) + "\n")
            print(f"Wrote: data/agents/bench-review.md ({len(reviews)} findings)", flush=True)
            # Print actionable findings inline so they're visible without reading the file
            actionable = [r for r in reviews
                          if r["review"].get("fix_type") not in ("none", "unknown")]
            if actionable:
                print("", flush=True)
                for r in actionable:
                    rv = r["review"]
                    print(f"  [{rv.get('fix_type')} conf={rv.get('confidence')}] "
                          f"{r['task']}/{r['model']}: {rv.get('root_cause', '?')}", flush=True)
                    if rv.get("fix"):
                        print(f"    → {rv['fix']}", flush=True)
        else:
            print("\n(auto-review: no interesting cases — all tasks passing with comfortable margins)",
                  flush=True)

    # Drop one summary line into log.jsonl so the Console "Recent runs" table
    # shows when benches happened (mixed in with normal wrapper invocations).
    # The frontend treats "bench-summary" tasks as informational rows.
    cells_total  = sum(s["trials"] for tasks in agg.values() for s in tasks.values())
    # Sum exact pass counts — never round-trip through the 2-decimal pass_rate
    # (int(0.33*3)==0 would undercount a real 1-of-3).
    cells_passed = sum(s["passes"] for tasks in agg.values() for s in tasks.values())
    summary = {
        "started_at":     started,
        "task":           "bench-summary",
        "model":          DEFAULT_MODEL,
        "latency_s":      0,
        "stop":           "ok",
        "tokens_in":      sum(r.get("tokens_in", 0)  for r in all_results),
        "tokens_out":     sum(r.get("tokens_out", 0) for r in all_results),
        "prompt_preview": f"agent-bench{' --force' if args.force else ''}{' --quick' if args.quick else ''}",
        "output_preview": f"{cells_passed}/{cells_total} cells passed across "
                          f"{len(set(r['model'] for r in all_results))} model(s) "
                          f"({len(skipped)} skipped via --smart)",
        "exit":           0,
    }
    with open(DATA_DIR / "log.jsonl", "a") as f:
        f.write(json.dumps(summary) + "\n")


if __name__ == "__main__":
    try:
        main()
    finally:
        _clear_active()       # don't leave a stale "running" indicator
        release_bench_lock()  # always drop the lock, even on error/Ctrl-C
