#!/usr/bin/env python3
"""scripts/agent-bench — empirical task→model routing benchmark.

Self-adapts to the host: queries omlx /v1/models/status for available memory,
loads one model at a time when memory is tight, runs each task N times per
model, scores latency + format compliance, picks the best (model, max_tokens)
per task, and writes data/agents/routing.json for the wrapper to pick up.

Usage:
    scripts/agent-bench               # full bench, default 3 trials
    scripts/agent-bench --trials 5    # more trials = lower variance
    scripts/agent-bench --quick       # 1 trial, default model only
    scripts/agent-bench --task TASK   # bench only one task (debugging)

Outputs:
    data/agents/bench-results.json    raw per-trial data
    data/agents/bench-report.md       human-readable summary
    data/agents/routing.json          chosen model/max_tokens per task
"""
import argparse
import json
import os
import re
import statistics
import subprocess
import sys
import time
import urllib.request
import urllib.error
from pathlib import Path

ROOT      = Path(__file__).resolve().parent.parent
DATA_DIR  = ROOT / "data" / "agents"
ACTIVE    = DATA_DIR / "active.json"      # console reads this for the "running" card
TASKS_JSON= ROOT / "config" / "agents" / "tasks.json"
OMLX_URL  = os.environ.get("OMLX_URL", "http://localhost:8000")
RESERVE_GB = 4   # keep this much headroom on top of omlx's own max_model_memory

DEFAULT_MODEL = "Qwen3.5-9B-MLX-4bit"


def load_api_key() -> str:
    env = ROOT / ".env"
    if env.exists():
        for line in env.read_text().splitlines():
            if line.startswith("OMLX_API_KEY="):
                v = line.split("=", 1)[1].rstrip("\r").strip()
                # Strip surrounding quotes (Windows-style or POSIX-style)
                if len(v) >= 2 and v[0] in '"\'' and v[-1] == v[0]:
                    v = v[1:-1]
                return v
    return os.environ.get("OMLX_API_KEY", "")


KEY = load_api_key()
HEADERS = {"Authorization": f"Bearer {KEY}", "Content-Type": "application/json"}


def http(method: str, path: str, body: dict | None = None, timeout: int = 120):
    url = OMLX_URL + path
    data = json.dumps(body).encode() if body else None
    req = urllib.request.Request(url, method=method, data=data, headers=HEADERS)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.status, json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        try:
            return e.code, json.loads(e.read().decode())
        except Exception:
            return e.code, {"error": str(e)}
    except Exception as e:
        return 0, {"error": str(e)}


# ─── task definitions ────────────────────────────────────────────────────────
# Single source of truth: config/agents/tasks.json (shared with scripts/agent).
# Each task contains: max_tokens, system, bench_prompt, compliant (regex string
# with inline flag prefixes — (?s) for DOTALL, (?i) for IGNORECASE).
def _load_tasks() -> dict:
    if not TASKS_JSON.exists():
        sys.exit(f"task config not found at {TASKS_JSON} — install gateii completely")
    raw = json.loads(TASKS_JSON.read_text())
    out = {}
    for name, t in raw.get("tasks", {}).items():
        try:
            out[name] = {
                "max_tokens": int(t["max_tokens"]),
                "system":     t["system"],
                "prompt":     t["bench_prompt"],
                "compliant":  re.compile(t["compliant"]),
            }
        except (KeyError, re.error) as e:
            sys.exit(f"tasks.json[{name}]: {e}")
    return out


TASKS = _load_tasks()


# ─── memory management ──────────────────────────────────────────────────────
def models_status():
    code, data = http("GET", "/v1/models/status")
    if code != 200:
        sys.exit(f"omlx /v1/models/status failed: {data}")
    return data


def gb(b): return b / (1024**3)


def ensure_model(model_id: str, status: dict) -> dict:
    """Load model_id; unload others if budget tight. Returns updated status."""
    info = next((m for m in status["models"] if m["id"] == model_id), None)
    if not info:
        sys.exit(f"unknown model: {model_id}")

    if info["loaded"]:
        return status  # already loaded, nothing to do

    needed     = info["estimated_size"]
    max_mem    = status["max_model_memory"]
    headroom   = max_mem - status["current_model_memory"] - RESERVE_GB * 1024**3

    if needed > headroom:
        # Free space: evict everything except the default model (which we want sticky)
        for m in status["models"]:
            if m["loaded"] and m["id"] != DEFAULT_MODEL and m["id"] != model_id:
                print(f"  ⤵ unload {m['id']} ({gb(m['estimated_size']):.1f}GB) to fit {model_id}", flush=True)
                http("POST", f"/v1/models/{m['id']}/unload")

    print(f"  ⤴ loading {model_id} ({gb(needed):.1f}GB) — first call will be slow", flush=True)
    # oMLX has no public /v1/models/<id>/load endpoint via Bearer auth, so we
    # trigger the load via a tiny throwaway request. omlx loads on first call.
    http("POST", "/v1/messages", {
        "model": model_id, "max_tokens": 1, "chat_template_kwargs": {"enable_thinking": False},
        "messages": [{"role": "user", "content": "."}]
    }, timeout=300)
    return models_status()


def unload_after_bench(model_id: str) -> None:
    """Drop a model from RAM after we're done benching it. Default model stays
    loaded — the wrapper hits it constantly. Big models (Qwen3.6-35B at 20 GB)
    leave a lot of headroom when freed; small ones (gemma-4-e2b at 3.5 GB) are
    cheap to reload anyway."""
    if model_id == DEFAULT_MODEL:
        return
    print(f"  ⤵ unload {model_id} (bench done; default stays loaded)", flush=True)
    http("POST", f"/v1/models/{model_id}/unload")


# ─── benchmark ──────────────────────────────────────────────────────────────
def _write_active(task_name: str, model: str, trial: int, max_trials: int) -> None:
    """Make the bench visible on /console/agents while it runs.
    Uses 'bench:' prefix so it's distinguishable from real wrapper runs.
    """
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    payload = {
        "task": f"bench:{task_name} ({trial}/{max_trials})",
        "model": model,
        "max_tokens": TASKS[task_name]["max_tokens"],
        "started_at": time.strftime("%Y-%m-%dT%H:%M:%S"),
        "started_epoch": int(time.time()),
        "pid": str(os.getpid()),
        "prompt_preview": TASKS[task_name]["prompt"][:80].replace("\n", " "),
        "parent": {"cwd": str(ROOT), "ppid": str(os.getppid()),
                   "parent_cmd": "scripts/agent-bench", "session_id": ""},
    }
    tmp = ACTIVE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(payload))
    tmp.replace(ACTIVE)


def _clear_active() -> None:
    try: ACTIVE.unlink()
    except FileNotFoundError: pass


def call(model: str, task_name: str, trial: int, max_trials: int = 3) -> dict:
    t = TASKS[task_name]
    _write_active(task_name, model, trial, max_trials)
    body = {
        "model": model,
        "max_tokens": t["max_tokens"],
        "temperature": 0.2,
        "chat_template_kwargs": {"enable_thinking": False},
        "system": t["system"],
        "messages": [{"role": "user", "content": t["prompt"]}],
    }
    t0 = time.time()
    code, resp = http("POST", "/v1/messages", body, timeout=180)
    dt = time.time() - t0

    text, stop, in_tok, out_tok = "", "?", 0, 0
    if code == 200 and "content" in resp:
        text = (resp["content"][0] or {}).get("text", "") if resp["content"] else ""
        stop = resp.get("stop_reason", "?")
        u = resp.get("usage") or {}
        # Sum the three input-token fields (omlx quirk: input_tokens=0)
        in_tok = (u.get("input_tokens", 0)
                  + u.get("cache_creation_input_tokens", 0)
                  + u.get("cache_read_input_tokens", 0))
        out_tok = u.get("output_tokens", 0)

    text_strip = text.strip()
    compliant = bool(t["compliant"].match(text_strip))

    return dict(
        task=task_name, model=model, trial=trial,
        latency_s=round(dt, 3), http=code, stop=stop,
        tokens_in=in_tok, tokens_out=out_tok,
        compliant=compliant, output=text_strip[:300],
    )


def bench_model(model: str, tasks: list[str], trials: int) -> list[dict]:
    results = []
    for task in tasks:
        runs = []
        for i in range(trials):
            r = call(model, task, i + 1, trials)
            runs.append(r)
            mark = "✓" if r["compliant"] else "✗"
            print(f"    {mark} {task:22s} trial {i+1}/{trials}  {r['latency_s']:>5.2f}s  out={r['tokens_out']}", flush=True)
        results.extend(runs)
    return results


def aggregate(results: list[dict]) -> dict:
    """Group by (task, model), compute pass-rate + latency stats."""
    by = {}
    for r in results:
        by.setdefault((r["task"], r["model"]), []).append(r)

    agg = {}
    for (task, model), runs in by.items():
        lats = [r["latency_s"] for r in runs]
        passes = sum(1 for r in runs if r["compliant"])
        agg.setdefault(task, {})[model] = dict(
            trials=len(runs),
            pass_rate=round(passes / len(runs), 2),
            latency_p50=round(statistics.median(lats), 2),
            latency_max=round(max(lats), 2),
            tokens_out_avg=round(statistics.mean(r["tokens_out"] for r in runs), 1),
        )
    return agg


def pick_routing(agg: dict) -> dict:
    """For each task pick the (model) with highest pass_rate, ties broken by latency."""
    routing = {}
    for task, models in agg.items():
        ranked = sorted(
            models.items(),
            key=lambda kv: (-kv[1]["pass_rate"], kv[1]["latency_p50"]),
        )
        best_model, best_stats = ranked[0]
        routing[task] = dict(
            model=best_model,
            max_tokens=TASKS[task]["max_tokens"],
            pass_rate=best_stats["pass_rate"],
            latency_p50=best_stats["latency_p50"],
            picked_from=[m for m, _ in ranked],
        )
    return routing


def render_report(agg: dict, routing: dict, started_at: str) -> str:
    out = [f"# Agent Bench Report — {started_at}", ""]
    out.append("## Per-task pass-rate × model")
    out.append("")
    out.append("| Task | Model | Pass | p50 | max | out-tokens |")
    out.append("|---|---|---:|---:|---:|---:|")
    for task in sorted(agg):
        for model, s in sorted(agg[task].items()):
            out.append(f"| {task} | {model} | {int(s['pass_rate']*100)}% | {s['latency_p50']}s | {s['latency_max']}s | {s['tokens_out_avg']} |")
    out.append("")
    out.append("## Picked routing (data/agents/routing.json)")
    out.append("")
    out.append("| Task | Model | Pass | p50 |")
    out.append("|---|---|---:|---:|")
    for task in sorted(routing):
        r = routing[task]
        out.append(f"| {task} | {r['model']} | {int(r['pass_rate']*100)}% | {r['latency_p50']}s |")
    return "\n".join(out) + "\n"


# ─── main ───────────────────────────────────────────────────────────────────
def _load_existing_results():
    """Return previous bench-results.json (or {}) so --smart can skip cells."""
    p = DATA_DIR / "bench-results.json"
    if not p.exists():
        return {}
    try:
        return json.loads(p.read_text())
    except Exception:
        return {}


def _models_already_benched(prev: dict, model: str, created: int) -> bool:
    """True iff prev has results for this model AND its omlx-registration
    timestamp matches (so the model wasn't re-imported with new weights)."""
    if not prev or "results" not in prev:
        return False
    if (prev.get("model_created") or {}).get(model) != created:
        return False
    return any(r.get("model") == model for r in prev["results"])


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--trials", type=int, default=3)
    ap.add_argument("--quick", action="store_true", help="1 trial, default model only")
    ap.add_argument("--task", help="bench only this task name")
    ap.add_argument("--force", action="store_true",
                    help="re-bench all models even if results exist (overrides --smart, the default)")
    args = ap.parse_args()

    if not KEY:
        sys.exit("OMLX_API_KEY not in env or .env")

    DATA_DIR.mkdir(parents=True, exist_ok=True)
    started = time.strftime("%Y-%m-%dT%H:%M:%S")
    print(f"agent-bench • {started} • host={OMLX_URL}", flush=True)

    status = models_status()
    print(f"  RAM: {gb(status['current_model_memory']):.1f}/{gb(status['max_model_memory']):.1f} GB used, "
          f"{status['loaded_count']}/{status['model_count']} models loaded", flush=True)

    # Determine which models to bench
    available = [m["id"] for m in status["models"]]
    if args.quick:
        models_to_bench = [DEFAULT_MODEL]
    else:
        # Default: full bench on Qwen3.5-9B; reasoning-only on the other two
        # (they're slow but good at math — see earlier ad-hoc bench).
        models_to_bench = [DEFAULT_MODEL]
        for m in available:
            if m != DEFAULT_MODEL:
                models_to_bench.append(m)

    # Determine task subset per model
    tasks_full = [args.task] if args.task else list(TASKS.keys())
    if args.task and args.task not in TASKS:
        sys.exit(f"unknown task: {args.task}")

    # Small models (≤ SMALL_MODEL_GB) are fast enough to bench on the full task
    # suite; big models get only reasoning + classify (where they might shine
    # despite the latency cost). The default model is always full-bench.
    SMALL_MODEL_GB = 10
    sizes = {m["id"]: m["estimated_size"] for m in status["models"]}
    # Per-model omlx-registration timestamp — used by --smart and exported to
    # Prometheus via metrics.lua. Lets dashboards distinguish "model unchanged"
    # from "model updated and freshly benched".
    model_created = {m["id"]: m.get("created") or 0 for m in status["models"]}

    # --smart (default unless --force/--quick/--task): skip models whose results
    # already exist AND whose `created` timestamp matches.
    prev = {} if (args.force or args.quick or args.task) else _load_existing_results()
    skipped = []

    all_results = []
    # Carry forward existing per-model results that we're choosing to skip
    if prev and prev.get("results"):
        for r in prev["results"]:
            if _models_already_benched(prev, r["model"], model_created.get(r["model"])):
                all_results.append(r)

    for model in models_to_bench:
        size_gb = gb(sizes.get(model, 0))
        is_small = size_gb <= SMALL_MODEL_GB
        if model == DEFAULT_MODEL or args.task or args.quick or is_small:
            tasks = tasks_full
        else:
            tasks = [t for t in ["reasoning", "classify-yesno"] if t in tasks_full]
            if not tasks:
                continue

        if _models_already_benched(prev, model, model_created.get(model)):
            skipped.append(model)
            print(f"\n=== {model} ({size_gb:.1f} GB) — SKIP (cached, model unchanged; --force to override) ===", flush=True)
            continue

        size_label = f"{size_gb:.1f} GB" + (" — small, full bench" if (is_small and model != DEFAULT_MODEL) else "")
        print(f"\n=== {model} ({size_label}) — {len(tasks)} task(s) × {1 if args.quick else args.trials} trial(s) ===", flush=True)
        status = ensure_model(model, status)
        trials = 1 if args.quick else args.trials
        all_results.extend(bench_model(model, tasks, trials))
        # Free RAM before moving to the next model — keeps memory pressure
        # predictable and matches "bench sequentially, one model at a time".
        unload_after_bench(model)
        status = models_status()

    # Aggregate + decide
    agg = aggregate(all_results)
    routing = pick_routing(agg)

    # Persist
    (DATA_DIR / "bench-results.json").write_text(json.dumps({
        "started_at": started,
        "started_epoch": int(time.time()),
        "host": OMLX_URL,
        "trials_per_cell": 1 if args.quick else args.trials,
        "model_created": model_created,
        "skipped_models": skipped,
        "results": all_results,
    }, indent=2) + "\n")
    (DATA_DIR / "routing.json").write_text(json.dumps({
        "generated_at": started,
        "default_model": DEFAULT_MODEL,
        "routes": routing,
    }, indent=2) + "\n")
    report = render_report(agg, routing, started)
    (DATA_DIR / "bench-report.md").write_text(report)

    print("\n" + report, flush=True)
    print(f"\nWrote: data/agents/bench-results.json, routing.json, bench-report.md", flush=True)

    # Drop one summary line into log.jsonl so the Console "Recent runs" table
    # shows when benches happened (mixed in with normal wrapper invocations).
    # The frontend treats "bench-summary" tasks as informational rows.
    cells_total  = sum(s["trials"] for tasks in agg.values() for s in tasks.values())
    cells_passed = sum(int(s["pass_rate"] * s["trials"]) for tasks in agg.values() for s in tasks.values())
    summary = {
        "started_at":     started,
        "task":           "bench-summary",
        "model":          DEFAULT_MODEL,
        "latency_s":      0,
        "stop":           "ok",
        "tokens_in":      sum(r.get("tokens_in", 0)  for r in all_results),
        "tokens_out":     sum(r.get("tokens_out", 0) for r in all_results),
        "prompt_preview": f"agent-bench{' --force' if args.force else ''}{' --quick' if args.quick else ''}",
        "output_preview": f"{cells_passed}/{cells_total} cells passed across "
                          f"{len(set(r['model'] for r in all_results))} model(s) "
                          f"({len(skipped)} skipped via --smart)",
        "exit":           0,
    }
    with open(DATA_DIR / "log.jsonl", "a") as f:
        f.write(json.dumps(summary) + "\n")


if __name__ == "__main__":
    try:
        main()
    finally:
        _clear_active()  # don't leave a stale "running" indicator
