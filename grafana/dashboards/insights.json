    {
      "id": 6,
      "title": "Daily Costs vs Subscriptions",
      "description": "Dashed lines = daily equivalent of subscription prices. If your usage is below, API is cheaper.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_cost_dollars_total[1d]))",
          "legendFormat": "API Cost / Day",
          "refId": "A",
          "step": "1d"
        },
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "vector(0.67)",
          "legendFormat": "Pro ($20/mo)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "vector(3.33)",
          "legendFormat": "Max 5x ($100/mo)",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "vector(6.67)",
          "legendFormat": "Max 20x ($200/mo)",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "barMaxWidth": 24,
            "spanNulls": false,
            "lineWidth": 0,
            "gradientMode": "none"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "API Cost / Day"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#5b9aff",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/\\$/i"
            },
            "properties": [
              {
                "id": "custom.drawStyle",
                "value": "line"
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [8, 8]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pro ($20/mo)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Max 5x ($100/mo)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Max 20x ($200/mo)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
