          "expr": "sum(increase(gateii_tokens_total{type=\"cache_read\"}[24h])) / clamp_min(sum(increase(gateii_tokens_total{type=~\"input|cache_read|cache_creation\"}[24h])), 1) * 100",
          "legendFormat": "Cache Hit Rate",
          "instant": true
