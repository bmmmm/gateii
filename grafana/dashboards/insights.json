      "title": "Output / Input Ratio Trend",
      "description": "How much output the model generates per input token. Tracks verbosity over time.",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 48, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=\"output\"}[1h])) / clamp_min(sum(increase(gateii_tokens_total{type=\"input\"}[1h])), 1)", "legendFormat": "Output / Input"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 2,
          "custom": {"lineWidth": 2, "fillOpacity": 10, "spanNulls": false, "lineInterpolation": "smooth"},
          "color": {"fixedColor": "#ff9830", "mode": "fixed"}
        }
      },
      "options": {
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },

    {
      "id": 50,
      "title": "Rate Limits",
      "type": "row",
      "gridPos": {"x": 0, "y": 56, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },

    {
      "id": 51,
      "title": "Rate Limit Window \u2014 Tokens Remaining",
      "description": "Tokens left in current Anthropic rate limit window. Drops toward 0 as you use tokens; jumps back up when window resets.",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 57, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "gateii_rate_limit_tokens_remaining", "legendFormat": "Tokens remaining", "refId": "A"},
        {"datasource": {"type": "prometheus"}, "expr": "gateii_rate_limit_tokens_expired", "legendFormat": "Tokens wasted on reset", "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"lineWidth": 2, "fillOpacity": 15, "spanNulls": true},
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Tokens remaining"}, "properties": [
            {"id": "color", "value": {"fixedColor": "#73bf69", "mode": "fixed"}},
            {"id": "custom.fillOpacity", "value": 20}
          ]},
          {"matcher": {"id": "byName", "options": "Tokens wasted on reset"}, "properties": [
            {"id": "color", "value": {"fixedColor": "#ff9830", "mode": "fixed"}},
            {"id": "custom.drawStyle", "value": "bars"},
            {"id": "custom.fillOpacity", "value": 60}
          ]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },

    {
      "id": 52,
      "title": "Rate Limit Events \u2014 Wait Time",
      "description": "Seconds you had to wait after hitting 5h or weekly token limit. Gauge = last recorded wait time per limit type.",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 57, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "gateii_rate_limit_wait_seconds{limit_type=\"5h\"}", "legendFormat": "5h \u2014 {{model}} ({{user}})", "refId": "A"},
        {"datasource": {"type": "prometheus"}, "expr": "gateii_rate_limit_wait_seconds{limit_type=\"weekly\"}", "legendFormat": "weekly \u2014 {{model}} ({{user}})", "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"lineWidth": 0, "fillOpacity": 80, "drawStyle": "bars", "barMaxWidth": 16, "spanNulls": false},
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/5h/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#ff9830", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/weekly/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#f2495c", "mode": "fixed"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "lastNotNull"]}
      }
    },

    {
      "id": 53,
      "title": "Tokens at Rate Limit Hit",
      "description": "Cumulative tokens (input + output + cache) consumed by the time the rate limit was triggered.",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 65, "w": 24, "h": 6},
      "datasource": {"type": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "gateii_rate_limit_tokens_at_hit", "legendFormat": "{{user}} \u2014 {{model}} ({{limit_type}})", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient", "valueMode": "color"}
    },

    {
      "id": 60,
      "title": "Git (requires git-tracking plugin)",
      "type": "row",
      "gridPos": {"x": 0, "y": 71, "w": 24, "h": 1},
      "collapsed": true,
      "panels": [
        {
          "id": 61,
          "title": "Tokens / Commit",
          "description": "Tokens per git commit. Requires scripts/git-tracking.sh.",
          "type": "stat",
          "gridPos": {"x": 0, "y": 72, "w": 8, "h": 4},
          "datasource": {"type": "prometheus"},
          "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total[24h])) / clamp_min(sum(gateii_git_commits_24h), 1)", "legendFormat": "Tokens/Commit", "instant": true}],
          "fieldConfig": {
            "defaults": {
              "unit": "short", "decimals": 0,
              "color": {"mode": "thresholds"},
              "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5000}, {"color": "red", "value": 20000}]}
            }
          },
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
        },
        {
          "id": 62,
          "title": "Cost / Commit",
          "type": "stat",
          "gridPos": {"x": 8, "y": 72, "w": 8, "h": 4},
          "datasource": {"type": "prometheus"},
          "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total[24h])) / clamp_min(sum(gateii_git_commits_24h), 1)", "legendFormat": "$/Commit", "instant": true}],
          "fieldConfig": {
            "defaults": {
              "unit": "currencyUSD", "decimals": 3,
              "color": {"mode": "thresholds"},
              "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 2}]}
            }
          },
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
        },
        {
          "id": 63,
          "title": "Git Activity (24h)",
          "description": "Lines added/removed/files changed per repo.",
          "type": "bargauge",
          "gridPos": {"x": 16, "y": 72, "w": 8, "h": 4},
          "datasource": {"type": "prometheus"},
          "targets": [
            {"datasource": {"type": "prometheus"}, "expr": "gateii_git_lines_added_24h", "legendFormat": "{{repo}} +lines", "instant": true},
            {"datasource": {"type": "prometheus"}, "expr": "gateii_git_lines_removed_24h", "legendFormat": "{{repo}} -lines", "instant": true},
            {"datasource": {"type": "prometheus"}, "expr": "gateii_git_files_changed_24h", "legendFormat": "{{repo}} files", "instant": true}
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short", "decimals": 0,
              "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
            }
          },
          "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
        }
      ]
    }

  ]
}
