{
  "id": null,
  "uid": "gateii-insights",
  "title": "gateii \u2014 Insights",
  "tags": [
    "gateii",
    "insights"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 2,
      "title": "Prompts (24h)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_requests_total[24h]))",
          "legendFormat": "Prompts",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Tokens / Prompt",
      "description": "Average last 24h \u2014 lower = more efficient",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_tokens_total[24h])) / clamp_min(sum(increase(gateii_requests_total[24h])), 1)",
          "legendFormat": "Tokens/Prompt",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
