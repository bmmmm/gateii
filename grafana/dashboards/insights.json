{
  "id": null,
  "uid": "gateii-insights",
  "title": "gateii \u2014 Insights",
  "tags": ["gateii", "insights"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-30d", "to": "now"},
  "panels": [

    {
      "id": 1,
      "title": "Prompts (24h)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_requests_total[24h]))", "legendFormat": "Prompts", "instant": true}],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "#5b9aff", "value": null}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },

    {
      "id": 2,
      "title": "Tokens / Prompt (24h)",
      "description": "Average over last 24h \u2014 lower = more efficient",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total[24h])) / clamp_min(sum(increase(gateii_requests_total[24h])), 1)", "legendFormat": "Tokens/Prompt", "instant": true}],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 500}, {"color": "red", "value": 2000}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },

    {
      "id": 3,
      "title": "Cost / Prompt (24h)",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total[24h])) / clamp_min(sum(increase(gateii_requests_total[24h])), 1)", "legendFormat": "$/Prompt", "instant": true}],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.05}, {"color": "red", "value": 0.2}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },

    {
      "id": 4,
      "title": "Cache Hit Rate (24h)",
      "description": "Proportion of input tokens served from cache. Higher = cheaper.",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=\"cache_read\"}[24h])) / clamp_min(sum(increase(gateii_tokens_total{type=~\"input|cache_read|cache_creation\"}[24h])), 1) * 100", "legendFormat": "Cache Hit %", "instant": true}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 30}, {"color": "green", "value": 60}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },

    {
      "id": 5,
      "title": "Cache Savings (24h)",
      "description": "Cost avoided via prompt caching (cache reads cost 90% less than full input)",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total{type=\"cache_read\"}[24h])) * 9", "legendFormat": "Savings", "instant": true}],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },

    {
      "id": 6,
      "title": "Monthly Forecast",
      "description": "Projected monthly cost based on last 7 days",
      "type": "stat",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total[7d])) / 7 * 30", "legendFormat": "Forecast", "instant": true}],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 20}, {"color": "orange", "value": 100}, {"color": "red", "value": 200}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },

    {
      "id": 10,
      "title": "Daily Trend",
      "type": "row",
      "gridPos": {"x": 0, "y": 3, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },

    {
      "id": 11,
      "title": "Daily Costs vs Subscriptions",
      "description": "Dashed lines = daily equivalent of subscription prices. API is cheaper when bars stay below a line.",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 16, "h": 9},
      "datasource": {"type": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total[1d]))", "legendFormat": "API Cost / Day", "refId": "A", "interval": "1d"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(0.67)", "legendFormat": "Pro ($20/mo)", "refId": "B"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(3.33)", "legendFormat": "Max 5x ($100/mo)", "refId": "C"},
        {"datasource": {"type": "prometheus"}, "expr": "vector(6.67)", "legendFormat": "Max 20x ($200/mo)", "refId": "D"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "custom": {"drawStyle": "bars", "fillOpacity": 80, "barMaxWidth": 20, "spanNulls": false, "lineWidth": 0, "gradientMode": "none"},
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "API Cost / Day"}, "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/\\$/i"}, "properties": [
            {"id": "custom.drawStyle", "value": "line"},
            {"id": "custom.fillOpacity", "value": 0},
            {"id": "custom.lineWidth", "value": 1},
            {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [8, 8]}}
          ]},
          {"matcher": {"id": "byName", "options": "Pro ($20/mo)"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Max 5x ($100/mo)"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Max 20x ($200/mo)"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },

    {
      "id": 12,
      "title": "Efficiency Trend",
      "description": "Tokens per prompt over time. Declining = more efficient.",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 4, "w": 8, "h": 9},
      "datasource": {"type": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total[1h])) / clamp_min(sum(increase(gateii_requests_total[1h])), 1)", "legendFormat": "Tokens / Prompt"},
        {"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total[1h])) / clamp_min(sum(increase(gateii_requests_total[1h])), 1)", "legendFormat": "Cost / Prompt"}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"lineWidth": 2, "fillOpacity": 10, "spanNulls": false, "lineInterpolation": "smooth"},
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Cost / Prompt"}, "properties": [
            {"id": "unit", "value": "currencyUSD"},
            {"id": "decimals", "value": 3},
            {"id": "custom.axisPlacement", "value": "right"}
          ]},
          {"matcher": {"id": "byName", "options": "Tokens / Prompt"}, "properties": [
            {"id": "unit", "value": "short"},
            {"id": "decimals", "value": 0}
          ]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },

