{
  "id": null,
  "uid": "gateii-insights",
  "title": "gateii \u2014 Insights",
  "tags": [
    "gateii",
    "insights"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Aktivit\u00e4t",
      "description": "Prompt-Dichte \u00fcber Zeit \u2014 dunklere Felder = mehr Aktivit\u00e4t",
      "type": "heatmap",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_requests_total[$__interval]))",
          "legendFormat": "Prompts",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            }
          }
        }
      },
      "options": {
        "calculate": true,
        "calculation": {
          "xBuckets": {
            "mode": "size"
          },
          "yBuckets": {
            "mode": "count",
            "value": "10"
          }
        },
        "color": {
          "mode": "scheme",
          "scheme": "Greens",
          "steps": 128
        },
        "cellGap": 2,
        "filterValues": {
          "le": 0
        },
        "tooltip": {
          "show": true,
          "yHistogram": false
        },
        "yAxis": {
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 2,
      "title": "Prompts (24h)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_requests_total[24h]))",
          "legendFormat": "Prompts",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Tokens / Prompt",
      "description": "Durchschnitt letzte 24h \u2014 weniger = effizienter",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_tokens_total[24h])) / clamp_min(sum(increase(gateii_requests_total[24h])), 1)",
          "legendFormat": "Tokens/Prompt",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Kosten / Prompt",
      "description": "Durchschnittliche Kosten pro Prompt (24h)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_cost_dollars_total[24h])) / clamp_min(sum(increase(gateii_requests_total[24h])), 1)",
          "legendFormat": "$/Prompt",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Monatsprognose",
      "description": "Hochrechnung basierend auf den letzten 7 Tagen",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_cost_dollars_total[7d])) / 7 * 30",
          "legendFormat": "Prognose",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Tageskosten vs Abo-Modelle",
      "description": "Gestrichelte Linien = Tages\u00e4quivalent der Abo-Preise. Liegt dein Verbrauch darunter, ist API g\u00fcnstiger.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_cost_dollars_total[24h]))",
          "legendFormat": "API-Kosten / Tag",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "vector(0.67)",
          "legendFormat": "Pro ($20/mo)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "vector(3.33)",
          "legendFormat": "Max 5x ($100/mo)",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "vector(6.67)",
          "legendFormat": "Max 20x ($200/mo)",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "API-Kosten / Tag"
            },
            "properties": [
              {
                "id": "custom.fillOpacity",
                "value": 15
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pro ($20/mo)"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [10, 10]
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Max 5x ($100/mo)"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [10, 10]
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
