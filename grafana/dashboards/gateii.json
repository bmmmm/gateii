{
  "id": null,
  "uid": "gateii-proxy",
  "title": "gateii \u2014 LLM Proxy",
  "tags": ["gateii", "llm", "nutc"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now/M", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Requests (24h)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_requests_total[24h]))", "legendFormat": "Requests", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 2,
      "title": "Tokens (24h)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=~\"input|output\"}[24h]))", "legendFormat": "Tokens", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 500000}, {"color": "red", "value": 2000000}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 3,
      "title": "Estimated Costs (24h)",
      "description": "Based on active provider pricing in providers.json. Cache reads: 0.1x, cache writes: 1.25x.",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_cost_dollars_total[24h]))", "legendFormat": "Cost", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 4,
      "title": "Blocked Users",
      "description": "Number of users currently blocked (rate limit or manual). Red = at least one blocked user.",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(gateii_user_blocked) or vector(0)", "legendFormat": "Blocked", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 5,
      "title": "Token Rate by Model",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 3, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (rate(gateii_tokens_total{type=~\"input|output\"}[5m]))", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 6,
      "title": "Request Rate by Model",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 3, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (rate(gateii_requests_total[5m]))", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 7,
      "title": "Tokens (24h) by Model",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 11, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_tokens_total{type=~\"input|output\"}[24h]))", "legendFormat": "{{model}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 8,
      "title": "Cost (24h) by Model",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 11, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_cost_dollars_total[24h]))", "legendFormat": "{{model}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 3,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 9,
      "title": "Tokens This Month by Model",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 19, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_tokens_total{type=~\"input|output\"}[$__range]))", "legendFormat": "{{model}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 10,
      "title": "Cost This Month by Model",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 19, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (increase(gateii_cost_dollars_total[$__range]))", "legendFormat": "{{model}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 3,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 16,
      "title": "Rate Limit Window",
      "description": "Tokens remaining in current Anthropic rate limit window. Drops toward 0, resets on window boundary.",
      "type": "stat",
      "gridPos": {"x": 0, "y": 27, "w": 8, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "gateii_rate_limit_tokens_remaining", "legendFormat": "Remaining", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 100000}, {"color": "green", "value": 500000}]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 17,
      "title": "Shared Dict Free",
      "description": "Free bytes in nginx counters dict. If this reaches 0, metrics are silently dropped.",
      "type": "stat",
      "gridPos": {"x": 8, "y": 27, "w": 8, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "gateii_shared_dict_free_bytes{dict=\"counters\"}", "legendFormat": "Free bytes", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 10000}, {"color": "green", "value": 50000}]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 18,
      "title": "Cache Hit Rate (24h)",
      "description": "cache_read / (input + cache_read). Higher = cheaper prompt processing.",
      "type": "stat",
      "gridPos": {"x": 16, "y": 27, "w": 8, "h": 3},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=\"cache_read\"}[24h])) / clamp_min(sum(increase(gateii_tokens_total{type=~\"input|cache_read\"}[24h])), 1) * 100", "legendFormat": "Cache Hit %", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 30}, {"color": "green", "value": 60}]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 11,
      "title": "Top Users — Cost (24h)",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 30, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sort_desc(sum by (user) (increase(gateii_cost_dollars_total[24h])))", "legendFormat": "{{user}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 3,
          "color": {"mode": "palette-classic"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 19,
      "title": "Top Users — Requests (24h)",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 30, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sort_desc(sum by (user) (increase(gateii_requests_total[24h])))", "legendFormat": "{{user}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": {"mode": "palette-classic"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 13,
      "title": "Avg Latency by Model",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 38, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (rate(gateii_request_duration_ms_total[5m])) / clamp_min(sum by (model) (rate(gateii_requests_total[5m])), 1)", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 5}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 14,
      "title": "Error Rate by Model",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 38, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (rate(gateii_upstream_errors_total[5m]))", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#33ff66", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#a78bfa", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#5b9aff", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 15,
      "title": "Stop Reason Distribution",
      "description": "end_turn = completed normally | max_tokens = response truncated (max_tokens set too low)",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 46, "w": 24, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (reason, model) (increase(gateii_stop_reason_total[24h]))", "legendFormat": "{{reason}} / {{model}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/max_tokens/i"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/end_turn/i"},   "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    }
  ]
}
