    {
      "id": 1,
      "title": "Token-Rate (input + output)",
      "description": "Tokens pro Sekunde, aufgeteilt nach User, Modell und Typ",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by (user, model, type) (rate(gateii_tokens_total[5m]))",
          "legendFormat": "{{user}} / {{model}} / {{type}}"
