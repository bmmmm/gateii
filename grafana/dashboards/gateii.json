{
  "id": null,
  "uid": "gateii-proxy",
  "title": "gateii \u2014 LLM Proxy",
  "tags": [
    "gateii",
    "llm",
    "nutc"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now/M",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(gateii_requests_total[24h]))",
          "legendFormat": "Requests",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Tokens (24h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(gateii_tokens_total{type=~\"input|output\"}[24h]))",
          "legendFormat": "Tokens",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500000 },
              { "color": "red", "value": 2000000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Estimated Costs (24h)",
      "description": "Based on active provider pricing in providers.json. Cache reads: 0.1x, cache writes: 1.25x.",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(gateii_cost_dollars_total[24h]))",
          "legendFormat": "Cost",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Blocked Users",
      "description": "Number of users currently blocked (rate limit or manual). Red = at least one blocked user.",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(gateii_user_blocked) or vector(0)",
          "legendFormat": "Blocked",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Token Rate by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (model) (rate(gateii_tokens_total{type=~\"input|output\"}[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/sonnet/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33ff66", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/opus/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/haiku/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5b9aff", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Request Rate by Model",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 3, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (model) (rate(gateii_requests_total[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/sonnet/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33ff66", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/opus/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/haiku/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5b9aff", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Tokens (24h) by Model",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (model) (increase(gateii_tokens_total{type=~\"input|output\"}[24h]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/sonnet/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33ff66", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/opus/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/haiku/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5b9aff", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      }
    },
    {
      "id": 8,
      "title": "Cost (24h) by Model",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (model) (increase(gateii_cost_dollars_total[24h]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/sonnet/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33ff66", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/opus/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/haiku/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5b9aff", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      }
    },
    {
      "id": 9,
      "title": "Tokens This Month by Model",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (model) (increase(gateii_tokens_total{type=~\"input|output\"}[$__range]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/sonnet/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33ff66", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/opus/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/haiku/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5b9aff", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      }
    },
    {
      "id": 10,
      "title": "Cost This Month by Model",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (model) (increase(gateii_cost_dollars_total[$__range]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/sonnet/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33ff66", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/opus/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/haiku/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5b9aff", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      }
    },
    {
      "id": 11,
      "title": "Usage by User",
      "description": "Per-user breakdown: requests, tokens and cost for the last 24h and this month (since dashboard start of month).",
      "type": "table",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (user) (increase(gateii_requests_total[24h]))",
          "legendFormat": "{{user}}",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (user) (increase(gateii_tokens_total{type=~\"input|output\"}[24h]))",
          "legendFormat": "{{user}}",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (user) (increase(gateii_cost_dollars_total[24h]))",
          "legendFormat": "{{user}}",
          "instant": true,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (user) (increase(gateii_tokens_total{type=~\"input|output\"}[$__range]))",
          "legendFormat": "{{user}}",
          "instant": true,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (user) (increase(gateii_cost_dollars_total[$__range]))",
          "legendFormat": "{{user}}",
          "instant": true,
          "refId": "E"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "Requests 24h",
              "Value #B": "Tokens 24h",
              "Value #C": "Cost 24h",
              "Value #D": "Tokens This Month",
              "Value #E": "Cost This Month"
            },
            "indexByName": {
              "user": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Cost 24h" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 3 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cost This Month" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 3 }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Cost This Month", "desc": true }],
        "footer": {
          "show": true,
          "reducer": ["sum"],
          "fields": ["Value #A", "Value #B", "Value #C", "Value #D", "Value #E"]
        }
      }
    },
    {
      "id": 13,
      "title": "Avg Latency by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 35, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (model) (rate(gateii_request_duration_ms_total[5m])) / sum by (model) (rate(gateii_requests_total[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/sonnet/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33ff66", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/opus/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/haiku/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5b9aff", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 14,
      "title": "Error Rate by Model",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 35, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (model) (rate(gateii_upstream_errors_total[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/sonnet/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33ff66", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/opus/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/haiku/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5b9aff", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 15,
      "title": "Stop Reason Distribution",
      "description": "end_turn = completed normally | max_tokens = response truncated (max_tokens set too low)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (reason, model) (increase(gateii_stop_reason_total[24h]))",
          "legendFormat": "{{reason}} / {{model}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/max_tokens/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/end_turn/i" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      }
    }
  ]
}
