{
  "id": null,
  "uid": "gateii-proxy",
  "title": "gateii \u2014 LLM Proxy",
  "tags": [
    "gateii",
    "llm",
    "nutc"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now/M",
    "to": "now/M"
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests (24h)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_requests_total[24h]))",
          "legendFormat": "Requests",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Tokens (24h)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_tokens_total{type=~\"input|output\"}[24h]))",
          "legendFormat": "Tokens",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500000
              },
              {
                "color": "red",
                "value": 2000000
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Estimated Costs (24h)",
      "description": "Based on active provider pricing in providers.json. Cache reads: 0.1x, cache writes: 1.25x.",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_cost_dollars_total[24h]))",
          "legendFormat": "Cost",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Blocked Users",
      "description": "Number of users currently blocked (rate limit or manual). Red = at least one blocked user.",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(gateii_user_blocked) or vector(0)",
          "legendFormat": "Blocked",
