  "panels": [
    {
      "id": 9,
      "title": "Requests (24h)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(gateii_requests_total[24h]))",
          "legendFormat": "Requests",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
