{
  "id": null,
  "uid": "gateii-eff",
  "title": "gateii — Efficiency & Health",
  "tags": ["gateii", "efficiency"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {"from": "now-7d", "to": "now"},
  "links": [
    {"title": "Operations", "type": "link", "url": "/d/gateii-ops", "icon": "dashboard", "targetBlank": false},
    {"title": "Cost & Usage", "type": "link", "url": "/d/gateii-cost", "icon": "dollar", "targetBlank": false}
  ],
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {"type": "prometheus"},
        "query": "label_values(gateii_requests_total, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Cache Hit Rate (24h)",
      "description": "cache_read / (cache_read + cache_creation) — share of cacheable tokens served from cache.",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=\"cache_read\",model=~\"$model\"}[24h])) / clamp_min(sum(increase(gateii_tokens_total{type=~\"cache_read|cache_creation\",model=~\"$model\"}[24h])), 1)", "legendFormat": "Hit rate", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "decimals": 1, "min": 0, "max": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 0.3}, {"color": "green", "value": 0.7}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 2,
      "title": "Vision Requests Share (7d)",
      "description": "Fraction of requests with image content-blocks.",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_requests_by_modality_total{modality=\"vision\",model=~\"$model\"}[7d])) / clamp_min(sum(increase(gateii_requests_by_modality_total{model=~\"$model\"}[7d])), 1)", "legendFormat": "Vision", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "decimals": 1, "min": 0, "max": 1, "color": {"mode": "fixed", "fixedColor": "#B877D9"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 3,
      "title": "Cache Savings (30d)",
      "description": "Estimated savings from cache hits vs. paying full input price. Uses avg input price $3/Mtok × 0.9 multiplier.",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(increase(gateii_tokens_total{type=\"cache_read\",model=~\"$model\"}[30d])) * 3 * 0.9 / 1e6", "legendFormat": "Savings", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "#56A64B"}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 4,
      "title": "Rate Limit 7d Used (now)",
      "description": "Fraction of the 7-day Anthropic token window consumed.",
      "type": "gauge",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "gateii_rate_limit_7d_utilization", "legendFormat": "7d used", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "decimals": 2, "min": 0, "max": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.6}, {"color": "red", "value": 0.85}]}}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true}
    },
    {
      "id": 5,
      "title": "Cache Hit Rate Trend (7d)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(rate(gateii_tokens_total{type=\"cache_read\",model=~\"$model\"}[1h])) / clamp_min(sum(rate(gateii_tokens_total{type=~\"cache_read|cache_creation\",model=~\"$model\"}[1h])), 1)", "legendFormat": "hit rate", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "decimals": 2, "min": 0, "max": 1, "custom": {"lineWidth": 2, "fillOpacity": 15}, "color": {"mode": "fixed", "fixedColor": "#56A64B"}}
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 6,
      "title": "Rate Limit 5h Utilization Trend (7d)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "gateii_rate_limit_5h_utilization", "legendFormat": "5h used", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "decimals": 2, "min": 0, "max": 1, "custom": {"lineWidth": 2, "fillOpacity": 15}, "color": {"mode": "fixed", "fixedColor": "#FF9830"}}
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 7,
      "title": "Tokens per Prompt (7d trend)",
      "description": "Avg input+output tokens per request, per model.",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (rate(gateii_tokens_total{type=~\"input|output\",model=~\"$model\"}[1h])) / clamp_min(sum by (model) (rate(gateii_requests_total{model=~\"$model\"}[1h])), 1)", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "custom": {"lineWidth": 2, "fillOpacity": 5}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 8,
      "title": "Output/Input Ratio (7d trend)",
      "description": "Ratio of output tokens to input tokens. Higher = more generative work per prompt.",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (rate(gateii_tokens_total{type=\"output\",model=~\"$model\"}[1h])) / clamp_min(sum by (model) (rate(gateii_tokens_total{type=\"input\",model=~\"$model\"}[1h])), 1)", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 2, "custom": {"lineWidth": 2, "fillOpacity": 5}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 9,
      "title": "Tokens by Modality (7d)",
      "description": "Text vs. vision token split over the last 7 days.",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (modality) (increase(gateii_tokens_by_modality_total{type=~\"input|output\",model=~\"$model\"}[7d]))", "legendFormat": "{{modality}}", "instant": true, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/vision/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/text/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]}
        ]
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },
    {
      "id": 10,
      "title": "Avg Latency by Model (7d trend)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum by (model) (rate(gateii_request_duration_ms_total{model=~\"$model\"}[5m])) / clamp_min(sum by (model) (rate(gateii_requests_total{model=~\"$model\"}[5m])), 1)", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 5}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/opus/i"},   "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/sonnet/i"}, "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/haiku/i"},  "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    }
  ]
}
