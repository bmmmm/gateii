# gateii — NUTC production .env
# Copy to .env and fill in. Never commit .env.

# --- Required ---

# Admin API shared secret. Generate: openssl rand -hex 32
# Used by scripts/admin.sh, /console UI, and bootstrap create.
ADMIN_TOKEN=

# Grafana admin password. Login at /grafana or http://nutc:3001 with this.
GRAFANA_ADMIN_PASSWORD=

# --- Proxy mode ---
# apikey       — clients authenticate with proxy keys from data/keys.json
#                (recommended for multi-user server deployments).
# passthrough  — clients forward their own upstream API key; server adds nothing.
PROXY_MODE=apikey

# Server-side Anthropic key — only used when PROXY_MODE=apikey and a proxy key
# does not have its own upstream_key (structured keys.json allows per-key keys).
ANTHROPIC_API_KEY=

# Optional additional provider keys (only needed if apikey mode + shared upstream)
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# --- Bind addresses ---
# Keep ports bound to 127.0.0.1 so traefik / reverse-proxy fronts them.
# Set to 0.0.0.0 only for direct LAN access.
PROXY_BIND=127.0.0.1
PROXY_PORT=8888
GRAFANA_BIND=127.0.0.1
GRAFANA_PORT=3001

# External URL Grafana is served from (e.g. https://grafana.example.com).
# Needed when behind a reverse proxy for correct redirects + assets.
GRAFANA_ROOT_URL=

# --- Plugins ---
CONSOLE_ENABLED=1

# --- Retention ---
# How long Prometheus keeps time series. Prod default: 90d.
# Options: 30d, 90d, 180d, 365d, 0 (unlimited — disk risk).
HISTORY_RETENTION=90d

# --- Rate limit window ---
# Duration of the Anthropic token rate limit window in seconds.
# Default (empty): read from providers.json (window_seconds, default 18000 = 5h).
# RATE_LIMIT_5H_WINDOW_SECONDS=
